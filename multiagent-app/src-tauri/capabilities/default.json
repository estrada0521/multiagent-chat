{
  "identifier": "default",
  "description": "Default capabilities for Multiagent Chat",
  "remote": {
    "urls": [
      "https://127.0.0.1:*",
      "https://localhost:*",
      "http://127.0.0.1:*",
      "http://localhost:*"
    ]
  },
  "windows": ["main"],
  "permissions": [
    "allow-show-chat-header-menu",
    "core:default",
    "core:window:allow-start-dragging",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-stdin-write"
  ]
}
