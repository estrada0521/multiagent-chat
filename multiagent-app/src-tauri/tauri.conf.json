{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Multiagent Chat",
  "identifier": "com.multiagent.chat",
  "version": "1.0.8",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": {
      "../../agent_icons/": "multiagent-chat-repo/agent_icons/",
      "../../bin/": "multiagent-chat-repo/bin/",
      "../../docs/": "multiagent-chat-repo/docs/",
      "../../lib/": "multiagent-chat-repo/lib/",
      "../../sounds/": "multiagent-chat-repo/sounds/",
      "../../cloudflare-color.svg": "multiagent-chat-repo/cloudflare-color.svg",
      "../../hub-header-logo.webp": "multiagent-chat-repo/hub-header-logo.webp",
      "../../README.md": "multiagent-chat-repo/README.md",
      "../../README_jp.md": "multiagent-chat-repo/README_jp.md"
    }
  }
}
