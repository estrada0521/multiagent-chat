{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Multiagent Chat",
  "identifier": "com.multiagent.chat",
  "version": "1.0.9",
  "build": {
    "frontendDist": "../src",
    "devUrl": "https://localhost:8788"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": {
      "../../../assets/": "multiagent-chat-repo/assets/",
      "../../../apps/shared/": "multiagent-chat-repo/apps/shared/",
      "../../../apps/desktop/web/": "multiagent-chat-repo/apps/desktop/web/",
      "../../../apps/mobile/": "multiagent-chat-repo/apps/mobile/",
      "../../../bin/": "multiagent-chat-repo/bin/",
      "../../../ops/": "multiagent-chat-repo/ops/",
      "../../../providers/": "multiagent-chat-repo/providers/",
      "../../../src/": "multiagent-chat-repo/src/"
    }
  }
}
