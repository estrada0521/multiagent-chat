#!/usr/bin/env bash
set -euo pipefail

_HERE="${BASH_SOURCE[0]:-$0}"
while [[ -L "$_HERE" ]]; do
  _D="$(cd "$(dirname "$_HERE")" && pwd)"
  _T="$(readlink "$_HERE")"
  [[ "$_T" == /* ]] || _T="$_D/$_T"
  _HERE="$_T"
done
_SCRIPT_DIR="$(cd "$(dirname "$_HERE")" && pwd)"
ROOT="$(cd "$_SCRIPT_DIR/.." && pwd)"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'EOF'
Usage: setup/quickstart [tauri_start options]

Compatibility entry for the default desktop setup.
It forwards to `./tauri_app/tauri_start`, which builds and opens the Tauri app
with a local HTTP Hub by default.

PWA / phone access is a later upgrade step:
  1. Start and use the HTTP Tauri app first: ./tauri_app/tauri_start
  2. While the HTTP Hub is running, prepare PWA HTTPS: ./setup/pwa/enable
  3. Restart the app in HTTPS mode: ./tauri_app/tauri_start --local-https
EOF
  exit 0
fi

echo "quickstart: forwarding to ./tauri_app/tauri_start (HTTP desktop)." >&2
exec "$ROOT/tauri_app/tauri_start" "$@"
