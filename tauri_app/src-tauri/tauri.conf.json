{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Agent Window",
  "identifier": "com.multiagent.chat",
  "version": "1.0.9",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:8788"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": {
      "../../assets/": "multiagent-chat-repo/assets/",
      "../../apps/shared/": "multiagent-chat-repo/apps/shared/",
      "../../apps/desktop/web/": "multiagent-chat-repo/apps/desktop/web/",
      "../../apps/mobile/": "multiagent-chat-repo/apps/mobile/",
      "../../bin/": "multiagent-chat-repo/bin/",
      "../../backend_core/": "multiagent-chat-repo/backend_core/",
      "../../hub_backend/": "multiagent-chat-repo/hub_backend/",
      "../../server/": "multiagent-chat-repo/server/",
      "../../message_delivery/": "multiagent-chat-repo/message_delivery/",
      "../../workspace_sync/": "multiagent-chat-repo/workspace_sync/",
      "../../native_log_sync/": "multiagent-chat-repo/native_log_sync/",
      "../../auto_mode/": "multiagent-chat-repo/auto_mode/",
      "../../shortcut_command/": "multiagent-chat-repo/shortcut_command/"
    }
  }
}
