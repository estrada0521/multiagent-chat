#!/usr/bin/env bash

set -euo pipefail

_HERE="${BASH_SOURCE[0]:-$0}"
while [[ -L "$_HERE" ]]; do
  _D="$(cd "$(dirname "$_HERE")" && pwd)"
  _T="$(readlink "$_HERE")"
  [[ "$_T" == /* ]] || _T="$_D/$_T"
  _HERE="$_T"
done
_TAURI_DIR="$(cd "$(dirname "$_HERE")" && pwd)"
ROOT="$(cd "$_TAURI_DIR/.." && pwd)"

usage() {
  cat <<'EOF'
Usage: tauri_app/tauri_start [--dev] [--build-only] [--no-open] [--setup-only] [--local-https]

Desktop app entry:
  - caches tauri-cli under .multiagent/tools/tauri-cli on first use
  - builds and opens the local macOS .app by default
  - starts the local Hub over HTTP by default

Requires python3, tmux, and cargo on PATH; install them yourself before running.

Use --local-https only after enabling phone/PWA access with ./setup/pwa/enable.

Options:
  --dev         run `cargo tauri dev` instead of building a .app bundle
  --build-only  build the .app bundle but do not open it
  --no-open     alias for --build-only
  --setup-only  prepare dependencies/certificates, then exit (skip build)
  --local-https start the Tauri-launched Hub over HTTPS after PWA enablement
  --help        show this help
EOF
}

MODE="build"
OPEN_APP=1
SETUP_ONLY=0
LOCAL_HTTPS=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dev)
      MODE="dev"
      shift
      ;;
    --build-only|--no-open)
      OPEN_APP=0
      shift
      ;;
    --setup-only)
      SETUP_ONLY=1
      shift
      ;;
    --local-https)
      LOCAL_HTTPS=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "tauri_start: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

for _hp in /opt/homebrew/bin /usr/local/bin "$HOME/.cargo/bin"; do
  case ":${PATH:-}:" in *:"${_hp}":*) ;; *)
    [[ -d "$_hp" ]] && PATH="${_hp}:$PATH"
    ;;
  esac
done
export PATH

export CARGO_TARGET_DIR="${CARGO_TARGET_DIR:-$HOME/.cache/multiagent-tauri-target}"
mkdir -p "$CARGO_TARGET_DIR"

for _cmd in python3 tmux; do
  if ! command -v "$_cmd" >/dev/null 2>&1; then
    echo "tauri_start: $_cmd is required on PATH. Install it, then re-run ./tauri_app/tauri_start." >&2
    exit 1
  fi
done

if [[ "$LOCAL_HTTPS" == "1" ]]; then
  if [[ ! -f "$ROOT/.multiagent/pwa/enabled" ]]; then
    echo "tauri_start: PWA HTTPS is not enabled yet." >&2
    echo "tauri_start: start the HTTP app first, then run ./setup/pwa/enable." >&2
    exit 1
  fi
  if [[ ! -f "$ROOT/certs/cert.pem" || ! -f "$ROOT/certs/key.pem" ]]; then
    echo "tauri_start: local HTTPS certificates are missing." >&2
    echo "tauri_start: start the HTTP app first, then run ./setup/pwa/enable." >&2
    exit 1
  fi
fi

if [[ "$SETUP_ONLY" == "1" ]]; then
  cat <<EOF
tauri_start: setup complete.
tauri_start: build and open the app: ./tauri_app/tauri_start
tauri_start: rebuild only:           ./tauri_app/tauri-build
tauri_start: enable phone/PWA later: ./setup/pwa/enable
EOF
  exit 0
fi

if ! command -v cargo >/dev/null 2>&1; then
  echo "tauri_start: cargo is required for the desktop app." >&2
  echo "tauri_start: install Rust first (https://rustup.rs), then re-run this command." >&2
  exit 1
fi

if [[ "$(uname -s)" == "Darwin" ]] && ! xcode-select -p >/dev/null 2>&1; then
  echo "tauri_start: Xcode Command Line Tools are required on macOS." >&2
  echo "tauri_start: run \`xcode-select --install\`, then re-run this command." >&2
  exit 1
fi

TAURI_CLI_ROOT="$ROOT/.multiagent/tools/tauri-cli"
TAURI_CLI_BIN="$TAURI_CLI_ROOT/bin/cargo-tauri"

if ! cargo tauri --help >/dev/null 2>&1; then
  if [[ ! -x "$TAURI_CLI_BIN" ]]; then
    echo "tauri_start: installing tauri-cli into .multiagent/tools/tauri-cli..." >&2
    cargo install tauri-cli --version "^2" --locked --root "$TAURI_CLI_ROOT"
  fi
  PATH="$TAURI_CLI_ROOT/bin:$PATH"
  export PATH
fi

if ! cargo tauri --help >/dev/null 2>&1; then
  echo "tauri_start: tauri-cli is unavailable after installation." >&2
  exit 1
fi

mkdir -p "$ROOT/assets/sounds"
export MULTIAGENT_REPO_ROOT="$ROOT"
if [[ "$LOCAL_HTTPS" == "1" ]]; then
  export MULTIAGENT_TAURI_USE_HTTPS=1
else
  unset MULTIAGENT_TAURI_USE_HTTPS MULTIAGENT_ENABLE_LOCAL_HTTPS MULTIAGENT_CERT_FILE MULTIAGENT_KEY_FILE
fi

cd "$_TAURI_DIR/src-tauri"

if [[ "$MODE" == "dev" ]]; then
  exec cargo tauri dev
fi

cargo tauri build --bundles app

app_path="$(find "$CARGO_TARGET_DIR/release/bundle/macos" -maxdepth 1 -name '*.app' -print -quit)"
if [[ -z "$app_path" ]]; then
  echo "tauri_start: built app bundle was not found." >&2
  exit 1
fi

printf 'tauri_start: built app at %s\n' "$app_path"
if [[ "$OPEN_APP" == "1" ]]; then
  open "$app_path"
fi
