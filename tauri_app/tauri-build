#!/usr/bin/env bash

set -euo pipefail

_HERE="${BASH_SOURCE[0]:-$0}"
while [[ -L "$_HERE" ]]; do
  _D="$(cd "$(dirname "$_HERE")" && pwd)"
  _T="$(readlink "$_HERE")"
  [[ "$_T" == /* ]] || _T="$_D/$_T"
  _HERE="$_T"
done
_TAURI_DIR="$(cd "$(dirname "$_HERE")" && pwd)"
ROOT="$(cd "$_TAURI_DIR/.." && pwd)"

usage() {
  cat <<'EOF'
Usage: tauri_app/tauri-build [--dev] [--build-only] [--no-open] [--local-https]

Dev / rebuild helper: rebuild and open the macOS Tauri desktop app without
re-running the interactive setup. First-time users should run
`./tauri_app/tauri_start` instead.

python3, tmux, Rust / cargo, tauri-cli, and Xcode Command Line Tools must already be installed.

Options:
  --dev         run `cargo tauri dev`
  --build-only  build the .app bundle but do not open it
  --no-open     alias for --build-only
  --local-https require the opened app to use HTTPS
  --help        show this help
EOF
}

MODE="build"
OPEN_APP=1
LOCAL_HTTPS=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dev)
      MODE="dev"
      shift
      ;;
    --build-only|--no-open)
      OPEN_APP=0
      shift
      ;;
    --local-https)
      LOCAL_HTTPS=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "tauri-build: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

for _hp in /opt/homebrew/bin /usr/local/bin "$HOME/.cargo/bin"; do
  case ":${PATH:-}:" in *:"${_hp}":*) ;; *)
    [[ -d "$_hp" ]] && PATH="${_hp}:$PATH"
    ;;
  esac
done
export PATH

export CARGO_TARGET_DIR="${CARGO_TARGET_DIR:-$HOME/.agent-window/cache/tauri-target}"
mkdir -p "$CARGO_TARGET_DIR"

for _cmd in python3 tmux; do
  if ! command -v "$_cmd" >/dev/null 2>&1; then
    echo "tauri-build: $_cmd is required on PATH. Install it, then re-run ./tauri_app/tauri-build." >&2
    exit 1
  fi
done

PWA_ENABLED_FILE="${AGENT_WINDOW_STATE_DIR:-$HOME/.agent-window/state}/pwa/enabled"
if [[ "$LOCAL_HTTPS" != "1" && -f "$PWA_ENABLED_FILE" ]]; then
  LOCAL_HTTPS=1
fi

if [[ "$LOCAL_HTTPS" == "1" ]]; then
  if [[ ! -f "$PWA_ENABLED_FILE" ]]; then
    echo "tauri-build: PWA HTTPS is not enabled yet." >&2
    echo "tauri-build: start the HTTP app first, then run ./setup/pwa/enable." >&2
    exit 1
  fi
  CERTS_DIR="${AGENT_WINDOW_CERTS_DIR:-$HOME/.agent-window/state/certs}"
  if [[ ! -f "$CERTS_DIR/cert.pem" || ! -f "$CERTS_DIR/key.pem" ]]; then
    echo "tauri-build: local HTTPS certificates are missing." >&2
    echo "tauri-build: start the HTTP app first, then run ./setup/pwa/enable." >&2
    exit 1
  fi
fi

if ! command -v cargo >/dev/null 2>&1; then
  echo "tauri-build: cargo is required for the desktop app." >&2
  echo "tauri-build: install Rust first: https://rustup.rs" >&2
  exit 1
fi

if ! command -v xcode-select >/dev/null 2>&1 || ! xcode-select -p >/dev/null 2>&1; then
  echo "tauri-build: Xcode Command Line Tools are required." >&2
  echo "tauri-build: run \`xcode-select --install\`, then re-run this command." >&2
  exit 1
fi

if ! cargo tauri --help >/dev/null 2>&1; then
  echo "tauri-build: tauri-cli is required for the desktop app." >&2
  echo "tauri-build: install it with \`cargo install tauri-cli --version \"^2\" --locked\`, then re-run this command." >&2
  exit 1
fi

mkdir -p "$ROOT/assets/sounds"
export MULTIAGENT_REPO_ROOT="$ROOT"
if [[ "$LOCAL_HTTPS" == "1" ]]; then
  export MULTIAGENT_TAURI_USE_HTTPS=1
else
  unset MULTIAGENT_TAURI_USE_HTTPS MULTIAGENT_ENABLE_LOCAL_HTTPS MULTIAGENT_CERT_FILE MULTIAGENT_KEY_FILE
fi

cd "$_TAURI_DIR/src-tauri"

if [[ "$MODE" == "dev" ]]; then
  exec cargo tauri dev
fi

cargo tauri build --bundles app

app_path="$(find "$CARGO_TARGET_DIR/release/bundle/macos" -maxdepth 1 -name '*.app' -print -quit)"
if [[ -z "$app_path" ]]; then
  echo "tauri-build: built app bundle was not found." >&2
  exit 1
fi

printf 'tauri-build: built app at %s\n' "$app_path"
if [[ "$OPEN_APP" == "1" ]]; then
  open "$app_path"
fi
