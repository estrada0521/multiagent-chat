#!/usr/bin/env python3
from __future__ import annotations

import argparse
import fcntl
import json
import os
import sys
import uuid
from datetime import datetime
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from lib.agent_index.gemini_direct import (
    DEFAULT_MODEL,
    GeminiRequest,
    event_jsonl_line,
    read_prompt_text,
    run_gemini_event_stream,
)


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="Run Gemini Developer API directly and bridge the result into multiagent chat JSONL."
    )
    p.add_argument("prompt", nargs="*", help="Prompt text. If omitted, stdin is used.")
    p.add_argument("--session", default=os.environ.get("MULTIAGENT_SESSION", ""), help="Session name.")
    p.add_argument(
        "--workspace",
        default=os.environ.get("MULTIAGENT_WORKSPACE", os.getcwd()),
        help="Workspace path used to resolve the session log directory.",
    )
    p.add_argument(
        "--log-dir",
        default=os.environ.get("MULTIAGENT_LOG_DIR", ""),
        help="Optional workspace log root. Defaults to <workspace>/logs when omitted.",
    )
    p.add_argument("--sender", default="gemini", help="Chat sender name for the final response.")
    p.add_argument("--target", default="user", help="Comma-separated chat targets for the final response.")
    p.add_argument("--reply-to", default="", help="Optional msg_id to reply to in chat.")
    p.add_argument("--model", default=DEFAULT_MODEL, help=f"Gemini model name (default: {DEFAULT_MODEL})")
    p.add_argument("--system", default="", help="Optional system instruction text.")
    p.add_argument("--temperature", type=float, default=None, help="Optional generationConfig.temperature")
    p.add_argument(
        "--max-output-tokens",
        type=int,
        default=None,
        help="Optional generationConfig.maxOutputTokens",
    )
    p.add_argument(
        "--api-key-env",
        default="",
        help="Optional env var name to read the API key from before trying GEMINI_API_KEY/GOOGLE_API_KEY.",
    )
    p.add_argument(
        "--event-subdir",
        default="normalized-events/gemini-direct",
        help="Relative subdirectory under the session log directory for normalized event JSONL.",
    )
    return p.parse_args()


def local_timestamp() -> str:
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")


def unique_paths(paths: list[Path]) -> list[Path]:
    seen: set[str] = set()
    out: list[Path] = []
    for path in paths:
        key = str(path.resolve())
        if key in seen:
            continue
        seen.add(key)
        out.append(path)
    return out


def resolve_session_log_dir(base_dir: Path, session_name: str, *, create_missing: bool) -> Path | None:
    if not session_name:
        return None
    base_dir = base_dir.expanduser()
    if create_missing:
        base_dir.mkdir(parents=True, exist_ok=True)
    if not base_dir.exists():
        return None
    exact = base_dir / session_name
    if exact.exists():
        return exact
    matches = sorted(
        base_dir.glob(f"{session_name}_*/.agent-index.jsonl"),
        key=lambda path: (path.stat().st_mtime, path.stat().st_size, str(path)),
    )
    if matches:
        return matches[-1].parent
    if create_missing:
        exact.mkdir(parents=True, exist_ok=True)
        return exact
    return None


def session_log_dirs(repo_root: Path, workspace: Path, session_name: str, explicit_log_dir: str) -> list[Path]:
    workspace_log_root = Path(explicit_log_dir).expanduser() if explicit_log_dir.strip() else workspace / "logs"
    candidates = [
        resolve_session_log_dir(workspace_log_root, session_name, create_missing=True),
        resolve_session_log_dir(repo_root / "logs", session_name, create_missing=True),
    ]
    return unique_paths([path for path in candidates if path is not None])


def append_jsonl_entry(paths: list[Path], entry: dict) -> None:
    line = json.dumps(entry, ensure_ascii=False) + "\n"
    for path in paths:
        path.parent.mkdir(parents=True, exist_ok=True)
        with path.open("a", encoding="utf-8") as f:
            fcntl.flock(f.fileno(), fcntl.LOCK_EX)
            try:
                f.write(line)
                f.flush()
            finally:
                fcntl.flock(f.fileno(), fcntl.LOCK_UN)


def lookup_reply_preview(index_paths: list[Path], reply_to: str) -> str:
    target = (reply_to or "").strip()
    if not target:
        return ""
    for path in index_paths:
        if not path.exists():
            continue
        try:
            with path.open("r", encoding="utf-8", errors="replace") as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    entry = json.loads(line)
                    if str(entry.get("msg_id") or "") != target:
                        continue
                    message = str(entry.get("message") or "")
                    if "[From:" in message:
                        close = message.find("]")
                        if close != -1:
                            message = message[close + 1 :].strip()
                    preview = message[:80].replace("\n", " ").strip()
                    sender = str(entry.get("sender") or "unknown")
                    return f"{sender}: {preview}" if preview else sender
        except Exception:
            continue
    return ""


def append_system_entry(
    index_paths: list[Path],
    *,
    session_name: str,
    message: str,
    run_id: str,
    model: str,
    event_path: str,
    provider_event: str,
    status: str,
    error: str = "",
) -> str:
    msg_id = uuid.uuid4().hex[:12]
    entry = {
        "timestamp": local_timestamp(),
        "session": session_name,
        "sender": "system",
        "targets": [],
        "message": message,
        "msg_id": msg_id,
        "kind": "provider-run",
        "provider": "gemini",
        "provider_vendor": "google",
        "provider_adapter": "gemini-direct",
        "provider_event": provider_event,
        "provider_status": status,
        "provider_model": model,
        "run_id": run_id,
        "normalized_event_path": event_path,
    }
    if error:
        entry["provider_error"] = error
    append_jsonl_entry(index_paths, entry)
    return msg_id


def append_response_entry(
    index_paths: list[Path],
    *,
    session_name: str,
    sender: str,
    targets: list[str],
    message: str,
    reply_to: str,
    reply_preview: str,
    run_id: str,
    model: str,
    event_path: str,
) -> str:
    msg_id = uuid.uuid4().hex[:12]
    entry = {
        "timestamp": local_timestamp(),
        "session": session_name,
        "sender": sender,
        "targets": targets,
        "message": message,
        "msg_id": msg_id,
        "provider": "gemini",
        "provider_vendor": "google",
        "provider_adapter": "gemini-direct",
        "provider_model": model,
        "run_id": run_id,
        "normalized_event_path": event_path,
    }
    if reply_to:
        entry["reply_to"] = reply_to
    if reply_preview:
        entry["reply_preview"] = reply_preview
    append_jsonl_entry(index_paths, entry)
    return msg_id


def main() -> int:
    args = parse_args()
    session_name = args.session.strip()
    if not session_name:
        raise SystemExit("--session or MULTIAGENT_SESSION is required.")
    try:
        prompt = read_prompt_text(args.prompt)
    except RuntimeError as exc:
        raise SystemExit(str(exc))

    repo_root = Path(__file__).resolve().parent.parent
    workspace = Path(args.workspace).expanduser().resolve()
    log_dirs = session_log_dirs(repo_root, workspace, session_name, args.log_dir)
    if not log_dirs:
        raise SystemExit(f"Could not resolve a log directory for session: {session_name}")
    index_paths = [path / ".agent-index.jsonl" for path in log_dirs]

    request = GeminiRequest(
        model=args.model,
        system=args.system,
        temperature=args.temperature,
        max_output_tokens=args.max_output_tokens,
        api_key_env=args.api_key_env,
        session=session_name,
        include_raw_payload=True,
    )
    run_id = request.run_id.strip() or uuid.uuid4().hex[:12]
    request = GeminiRequest(
        model=request.model,
        system=request.system,
        temperature=request.temperature,
        max_output_tokens=request.max_output_tokens,
        api_key_env=request.api_key_env,
        session=request.session,
        run_id=run_id,
        adapter=request.adapter,
        provider=request.provider,
        vendor=request.vendor,
        include_raw_payload=request.include_raw_payload,
    )
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    relative_event_path = str(Path(args.event_subdir) / f"{stamp}_{run_id}.jsonl")
    event_paths = [path / relative_event_path for path in log_dirs]

    append_system_entry(
        index_paths,
        session_name=session_name,
        message=f"Gemini direct run started · {request.model}",
        run_id=run_id,
        model=request.model,
        event_path=relative_event_path,
        provider_event="response.started",
        status="started",
    )

    def on_event(event: dict) -> None:
        for path in event_paths:
            path.parent.mkdir(parents=True, exist_ok=True)
            with path.open("a", encoding="utf-8") as f:
                f.write(event_jsonl_line(event) + "\n")

    try:
        summary = run_gemini_event_stream(prompt, request, on_event=on_event)
    except RuntimeError as exc:
        error = str(exc)
        append_system_entry(
            index_paths,
            session_name=session_name,
            message=f"Gemini direct run failed · {request.model}",
            run_id=run_id,
            model=request.model,
            event_path=relative_event_path,
            provider_event="response.error",
            status="error",
            error=error,
        )
        sys.stderr.write(error.rstrip() + "\n")
        return 1

    if not summary.ok:
        append_system_entry(
            index_paths,
            session_name=session_name,
            message=f"Gemini direct run failed · {request.model}",
            run_id=run_id,
            model=request.model,
            event_path=relative_event_path,
            provider_event="response.error",
            status="error",
            error=summary.error,
        )
        sys.stderr.write((summary.error or "Gemini direct run failed").rstrip() + "\n")
        return 1

    targets = [item.strip() for item in str(args.target or "").split(",") if item.strip()]
    reply_to = (args.reply_to or "").strip()
    reply_preview = lookup_reply_preview(index_paths, reply_to)
    output_text = summary.output_text.strip()
    if output_text:
        append_response_entry(
            index_paths,
            session_name=session_name,
            sender=(args.sender or "gemini").strip() or "gemini",
            targets=targets or ["user"],
            message=output_text,
            reply_to=reply_to,
            reply_preview=reply_preview,
            run_id=run_id,
            model=request.model,
            event_path=relative_event_path,
        )
    append_system_entry(
        index_paths,
        session_name=session_name,
        message=f"Gemini direct run completed · {request.model}" if output_text else f"Gemini direct run completed with no text output · {request.model}",
        run_id=run_id,
        model=request.model,
        event_path=relative_event_path,
        provider_event="response.completed",
        status="completed",
    )
    if output_text:
        sys.stdout.write(output_text + "\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
