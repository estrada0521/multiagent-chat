recover_session_pane_for_instance() {
  local session="$1" instance_name="$2"
  local recovered pane_id pane_title
  if session_uses_per_window_layout "$session"; then
    recovered="$(tmux list-panes -a -F '#{session_name}\t#{pane_id}\t#{window_name}' 2>/dev/null | awk -F '\t' -v session="$session" -v target="$instance_name" '$1 == session && $3 == target {print $2; exit}')"
    [[ -n "$recovered" ]] && printf '%s\n' "$recovered"
    return 0
  fi
  while IFS=$'\t' read -r _session pane_id pane_title; do
    [[ "$_session" == "$session" ]] || continue
    [[ -n "$pane_id" && "$pane_title" == "$instance_name" ]] || continue
    printf '%s\n' "$pane_id"
    return 0
  done < <(tmux list-panes -a -F '#{session_name}\t#{pane_id}\t#{pane_title}' 2>/dev/null || true)
  return 0
}

reconcile_session_agent_registry() {
  local session="$1" current_agents changed=0 recovered_any=0
  local instance upper pane_id recovered updated_agents=()
  current_agents="$(session_agents_value "$session")"
  [[ "$current_agents" == "-" ]] && current_agents=""
  [[ -n "$current_agents" ]] || return 0

  IFS=',' read -ra _instances <<< "$current_agents"
  for instance in "${_instances[@]}"; do
    [[ -n "$instance" ]] || continue
    upper="$(printf '%s' "$instance" | tr '[:lower:]-' '[:upper:]_')"
    pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    if [[ -n "$pane_id" ]] && ! tmux display-message -p -t "$pane_id" '#{pane_id}' >/dev/null 2>&1; then
      pane_id=""
      tmux set-environment -t "$session" -u "MULTIAGENT_PANE_${upper}" 2>/dev/null || true
      changed=1
    fi
    if [[ -z "$pane_id" ]]; then
      recovered="$(recover_session_pane_for_instance "$session" "$instance")"
      if [[ -n "$recovered" ]]; then
        tmux set-environment -t "$session" "MULTIAGENT_PANE_${upper}" "$recovered"
        pane_id="$recovered"
        recovered_any=1
        changed=1
      fi
    fi
    if [[ -n "$pane_id" ]]; then
      updated_agents+=("$instance")
    else
      changed=1
    fi
  done

  if [[ "$changed" -eq 1 ]]; then
    if ((${#updated_agents[@]} > 0)); then
      tmux set-environment -t "$session" MULTIAGENT_AGENTS "$(IFS=,; echo "${updated_agents[*]}")"
    else
      tmux set-environment -t "$session" -u MULTIAGENT_AGENTS 2>/dev/null || true
    fi
    write_session_state_file "$session"
  fi

  if [[ "$recovered_any" -eq 1 ]]; then
    printf 'recovered\n'
  fi
}

session_agents_value() {
  local session="$1"
  local agents_str
  agents_str="$(tmux show-environment -t "$session" MULTIAGENT_AGENTS 2>/dev/null | sed 's/^[^=]*=//' || true)"
  if [[ -n "$agents_str" ]]; then
    printf '%s\n' "$agents_str"
    return
  fi
  # Fallback for old sessions
  local agents=() agent upper pane_id
  for agent in "${ALL_AGENTS[@]}"; do
    upper="$(printf '%s' "$agent" | tr '[:lower:]' '[:upper:]')"
    pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    [[ -n "$pane_id" ]] && agents+=("$agent")
  done
  ((${#agents[@]} > 0)) && printf '%s\n' "$(IFS=,; echo "${agents[*]}")" || printf '%s\n' "-"
}

next_instance_name() {
  local session="$1" base_agent="$2"
  local agents_str
  agents_str="$(session_agents_value "$session")"
  python3 - "$REPO_ROOT" "$agents_str" "$base_agent" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
agents_csv = sys.argv[2]
base_agent = sys.argv[3]
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_agent_core import parse_agents_csv, next_instance_name

print(next_instance_name(parse_agents_csv(agents_csv), base_agent))
PYEOF
}

renumber_existing_exact_instance() {
  local session="$1" base_agent="$2"
  local current_agents renumber_plan replacement old_instance updated_agents
  current_agents="$(session_agents_value "$session")"
  renumber_plan="$(python3 - "$REPO_ROOT" "$current_agents" "$base_agent" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
agents_csv = sys.argv[2]
base_agent = sys.argv[3]
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_agent_core import agents_to_csv, parse_agents_csv, renumber_exact_instance

updated, rename = renumber_exact_instance(parse_agents_csv(agents_csv), base_agent)
if not rename:
    raise SystemExit(0)

print(agents_to_csv(updated))
print(rename[0])
print(rename[1])
PYEOF
  )"
  [[ -n "$renumber_plan" ]] || return 0

  updated_agents="$(printf '%s\n' "$renumber_plan" | sed -n '1p')"
  old_instance="$(printf '%s\n' "$renumber_plan" | sed -n '2p')"
  replacement="$(printf '%s\n' "$renumber_plan" | sed -n '3p')"
  [[ -n "$replacement" ]] || return 0

  local upper_old upper_replacement pane_id
  upper_old="$(printf '%s' "$old_instance" | tr '[:lower:]-' '[:upper:]_')"
  upper_replacement="$(printf '%s' "$replacement" | tr '[:lower:]-' '[:upper:]_')"
  pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper_old}" 2>/dev/null | sed 's/^[^=]*=//' || true)"

  if [[ -n "$pane_id" ]]; then
    tmux set-environment -t "$session" "MULTIAGENT_PANE_${upper_replacement}" "$pane_id"
    tmux set-environment -t "$session" -u "MULTIAGENT_PANE_${upper_old}" 2>/dev/null || true
    tmux select-pane -t "$pane_id" -T "$replacement" >/dev/null 2>&1 || true
    if session_uses_per_window_layout "$session"; then
      local window_target
      window_target="$(window_target_for_pane "$pane_id")"
      [[ -n "$window_target" ]] && tmux rename-window -t "$window_target" "$replacement" >/dev/null 2>&1 || true
    fi
  fi
  if [[ -n "$updated_agents" ]]; then
    tmux set-environment -t "$session" MULTIAGENT_AGENTS "$updated_agents"
  else
    tmux set-environment -t "$session" -u MULTIAGENT_AGENTS 2>/dev/null || true
  fi
  write_session_state_file "$session"
}

write_session_state_file() {
  local session="$1" agents_str state_path env_output
  agents_str="$(tmux show-environment -t "$session" MULTIAGENT_AGENTS 2>/dev/null | sed 's/^[^=]*=//' || true)"
  state_path="$(multiagent_panes_state_path "$TMUX_SOCKET_NAME" "$session")"
  env_output="$(tmux show-environment -t "$session" 2>/dev/null || true)"
  printf '%s' "$env_output" | python3 - "$REPO_ROOT" "$state_path" "$session" "$agents_str" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
state_path = Path(sys.argv[2])
session = sys.argv[3]
agents_csv = sys.argv[4]
tmux_env_output = sys.stdin.read()
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_state_core import write_session_state_file as write_state_file

write_state_file(state_path, session, agents_csv, tmux_env_output)
PYEOF
}

session_agent_state_lines() {
  local session="$1" instance upper pane_id pane_title pane_dead pane_current_command
  local agents_str
  agents_str="$(session_agents_value "$session")"
  [[ "$agents_str" == "-" ]] && return 0
  IFS=',' read -ra agent_list <<< "$agents_str"
  for instance in "${agent_list[@]}"; do
    upper="$(printf '%s' "$instance" | tr '[:lower:]-' '[:upper:]_')"
    pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    if [[ -z "$pane_id" ]]; then
      printf '  - %s: not configured\n' "$instance"
      continue
    fi
    pane_title="$(tmux display-message -p -t "$pane_id" '#{pane_title}' 2>/dev/null || true)"
    pane_dead="$(tmux display-message -p -t "$pane_id" '#{pane_dead}' 2>/dev/null || true)"
    pane_current_command="$(tmux display-message -p -t "$pane_id" '#{pane_current_command}' 2>/dev/null || true)"
    if [[ "$pane_dead" == "1" ]]; then
      printf '  - %s: pane=%s dead title=%s\n' "$instance" "$pane_id" "${pane_title:-unknown}"
    else
      printf '  - %s: pane=%s running cmd=%s title=%s\n' "$instance" "$pane_id" "${pane_current_command:-unknown}" "${pane_title:-unknown}"
    fi
  done
}

emit_session_save_hook() {
  local s_name="$1" hook_log_dir="$2" ws="$3" sock="$4"
  local _hook_script="/tmp/multiagent_save_${s_name}.sh"
  mkdir -p "$hook_log_dir"
  mkdir -p "$CENTRAL_LOG_DIR"
  cat > "$_hook_script" << HOOKEOF
#!/usr/bin/env bash
session='${s_name}'
reason="\${1:-manual}"
workspace_log_dir='${hook_log_dir}'
central_log_dir='${CENTRAL_LOG_DIR}'
workspace='${ws}'
tmux_socket='${sock}'

tmux() {
  case "\$tmux_socket" in
    /*) command tmux -S "\$tmux_socket" "\$@" ;;
    *) command tmux -L "\$tmux_socket" "\$@" ;;
  esac
}

session_log_dir() {
  local base_dir="\$1"
  local created_epoch created_at updated_at old_dir session_dir
  created_epoch="\$(tmux display-message -p -t "\$session" '#{session_created}' 2>/dev/null || true)"
  if [[ -n "\$created_epoch" ]]; then
    created_at="\$(date -r "\$created_epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date '+%Y-%m-%d %H:%M:%S')"
  else
    created_at="\$(date '+%Y-%m-%d %H:%M:%S')"
  fi
  updated_at="\$(date '+%Y-%m-%d %H:%M:%S')"
  mkdir -p "\$base_dir"
  session_dir="\${base_dir}/\${session}"
  if [[ ! -d "\$session_dir" ]]; then
    old_dir="\$(find \"\$base_dir\" -maxdepth 1 -type d -name \"\${session}_*\" 2>/dev/null | sort | tail -n 1)"
    if [[ -n "\$old_dir" ]] && [[ "\$old_dir" != "\$session_dir" ]]; then
      mv "\$old_dir" "\$session_dir"
    else
      mkdir -p "\$session_dir"
    fi
  else
    mkdir -p "\$session_dir"
  fi
  printf '%s\t%s\t%s\n' "\$session_dir" "\$created_at" "\$updated_at"
}

update_meta() {
  local session_dir="\$1" created_at="\$2" updated_at="\$3" agents_csv="\${4:-}"
  local meta_file="\${session_dir}/.meta"
  python3 - "\$meta_file" "\$session" "\$workspace" "\$created_at" "\$updated_at" "\$reason" "\$agents_csv" <<'PYEOF'
import json, os, sys

path, session, workspace, created_at, updated_at, reason, agents_csv = sys.argv[1:8]
if os.path.exists(path):
    try:
        with open(path, "r") as f:
            data = json.load(f)
    except json.JSONDecodeError:
        try:
            with open(path, "r") as f:
                data, _ = json.JSONDecoder().raw_decode(f.read())
        except Exception:
            data = {"session": session, "workspace": workspace, "created_at": created_at, "updated_at": updated_at, "overwrite_count": 0, "overwrites": []}
else:
    data = {"session": session, "workspace": workspace, "created_at": created_at, "updated_at": updated_at, "overwrite_count": 0, "overwrites": []}

data["session"] = session
data["workspace"] = workspace
data["created_at"] = data.get("created_at", created_at)
data["updated_at"] = updated_at
overwrites = data.setdefault("overwrites", [])
overwrites.append({"timestamp": updated_at, "reason": reason})
data["overwrite_count"] = len(overwrites)
if agents_csv.strip():
    data["agents"] = [a.strip() for a in agents_csv.split(",") if a.strip()]

with open(path, "w") as f:
    json.dump(data, f, indent=2, ensure_ascii=True)
    f.write("\n")
PYEOF
}

save_to_dir() {
  local base_dir="\$1"
  local resolved session_dir created_at updated_at
  resolved="\$(session_log_dir "\$base_dir")"
  IFS=$'\t' read -r session_dir created_at updated_at <<< "\$resolved"
  local agents_str saved=0
  agents_str="\$(tmux show-environment -t "\$session" MULTIAGENT_AGENTS 2>/dev/null | sed 's/^[^=]*=//' || true)"
  [[ -z "\$agents_str" ]] && agents_str="$ALL_AGENTS_CSV"
  IFS=',' read -ra _hook_agents <<< "\$agents_str"
  for instance in "\${_hook_agents[@]}"; do
    upper="\$(printf '%s' "\$instance" | tr '[:lower:]-' '[:upper:]_')"
    pane_id="\$(tmux show-environment -t "\$session" "MULTIAGENT_PANE_\${upper}" 2>/dev/null | cut -d= -f2 || true)"
    [[ -z "\$pane_id" ]] && continue
    ans_file="\$session_dir/\${instance}.ans"
    txt_file="\$session_dir/\${instance}.log"
    tmux capture-pane -p -e -S - -t "\$pane_id" 2>/dev/null > "\$ans_file" || true
    perl -pe 's/\x1b\[[0-9;?]*[a-zA-Z]//g; s/\x1b\][^\x07]*\x07//g; s/\x1b[(){][AB012]//g; s/\x1b[=>]//g; s/\r//g' < "\$ans_file" > "\$txt_file" || true
    echo "[multiagent] Updated: \$txt_file" >&2
    saved=1
  done
  if [[ "\$saved" -eq 1 ]]; then
    update_meta "\$session_dir" "\$created_at" "\$updated_at" "\$agents_str"
    echo "[multiagent] Session log dir: \$session_dir" >&2
  fi
}

save_to_dir "\$workspace_log_dir"
if [[ "\$workspace_log_dir" != "\$central_log_dir" ]]; then
  save_to_dir "\$central_log_dir"
fi
HOOKEOF
  chmod +x "$_hook_script"
  tmux set-hook -t "$s_name" before-kill-session "run-shell '$_hook_script kill'" 2>/dev/null || true
  tmux set-hook -t "$s_name" client-detached   "run-shell '$_hook_script detach'" 2>/dev/null || true
}

session_dead_pane_count() {
  local session="$1"
  tmux list-panes -s -t "$session" -F '#{pane_dead}' 2>/dev/null | awk '$1==1 {c++} END {print c+0}'
}

session_status_summary() {
  local session="$1"
  local dead attached
  dead="$(session_dead_pane_count "$session")"
  attached="$(session_attached_value "$session")"
  if [[ "$dead" != "0" ]]; then
    printf 'degraded'
  elif [[ "$attached" != "0" ]]; then
    printf 'attached'
  else
    printf 'idle'
  fi
}

repo_sessions() {
  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    local bin_dir
    bin_dir="$(session_bin_dir_value "$session")"
    [[ -n "$bin_dir" ]] || continue
    bin_dir="$(realpath_or_echo "$bin_dir")"
    [[ "$bin_dir" == "$SCRIPT_DIR" ]] || continue
    printf '%s\n' "$session"
  done < <(tmux list-sessions -F '#S' 2>/dev/null || true)
}

archived_repo_sessions() {
  python3 - "$CENTRAL_LOG_DIR" <<'PYEOF'
import json
import os
import sys
from datetime import datetime

central_log_dir = os.path.realpath(sys.argv[1])

def format_mtime(path):
    try:
        return datetime.fromtimestamp(os.path.getmtime(path)).strftime("%Y-%m-%d %H:%M:%S")
    except OSError:
        return ""

def parse_session_dir(name):
    parts = name.split("_")
    if len(parts) >= 3 and all(len(part) == 6 and part.isdigit() for part in parts[-2:]):
        return "_".join(parts[:-2]) or name
    return name

records = {}
if os.path.isdir(central_log_dir):
    for entry in os.listdir(central_log_dir):
        path = os.path.join(central_log_dir, entry)
        if not os.path.isdir(path):
            continue
        meta_path = os.path.join(path, ".meta")
        index_path = os.path.join(path, ".agent-index.jsonl")
        if not os.path.exists(meta_path) and not os.path.exists(index_path):
            continue
        meta = {}
        if os.path.exists(meta_path):
            try:
                with open(meta_path, "r") as f:
                    meta = json.load(f)
            except Exception:
                meta = {}
        session = meta.get("session") or parse_session_dir(entry)
        created = meta.get("created_at") or format_mtime(path)
        updated = meta.get("updated_at") or format_mtime(path)
        # Detect agents from log/ans files (supports instance names like claude-1)
        agents = []
        for f in sorted(os.listdir(path)):
            base, ext = os.path.splitext(f)
            if ext in (".log", ".ans") and base not in agents and not base.startswith("."):
                agents.append(base)
        # Deduplicate keeping order (log and ans for same instance)
        seen = set()
        unique_agents = []
        for a in agents:
            if a not in seen:
                seen.add(a)
                unique_agents.append(a)
        agents = unique_agents
        record = {
            "session": session,
            "workspace": meta.get("workspace") or "-",
            "created": created,
            "updated": updated,
            "agents": ",".join(agents) if agents else "-",
            "log_dir": path,
        }
        existing = records.get(session)
        if existing is None or (record["updated"], record["log_dir"]) > (existing["updated"], existing["log_dir"]):
            records[session] = record

for session in sorted(records):
    record = records[session]
    print(
        "\t".join(
            [
                record["session"],
                record["workspace"],
                record["created"],
                record["updated"],
                record["agents"],
                record["log_dir"],
            ]
        )
    )
PYEOF
}

latest_repo_session() {
  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    tmux display-message -p -t "$session" '#{session_created} #{session_name}' 2>/dev/null || true
  done < <(repo_sessions) | sort -nr | awk 'NR==1 {print $2}'
}

resolve_existing_session_name() {
  local default_name matched=()
  default_name="$(default_session_name)"

  if tmux has-session -t "=$default_name" 2>/dev/null; then
    printf '%s\n' "$default_name"
    return 0
  fi

  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    matched+=("$session")
  done < <(repo_sessions)

  if [[ ${#matched[@]} -eq 1 ]]; then
    printf '%s\n' "${matched[0]}"
    return 0
  fi

  if [[ ${#matched[@]} -gt 1 ]]; then
    printf 'Multiple sessions exist; specify --session: %s\n' "${matched[*]}" >&2
    return 1
  fi

  printf '%s\n' "$default_name"
}

resolve_target_session_name() {
  if [[ "$LATEST_SESSION" -eq 1 ]]; then
    latest_repo_session
    return 0
  fi
  resolve_existing_session_name
}

usage() {
  cat <<EOF
Usage:
  multiagent list [--verbose] [--all]
  multiagent [status] [--session NAME] [--all]
  multiagent context [--session NAME] [--json]
  multiagent brief [--session NAME]
  multiagent add-agent --session NAME --agent AGENT
  multiagent remove-agent --session NAME --agent INSTANCE
  multiagent resume [--session NAME | --latest] [--detach]
  multiagent kill [--session NAME | --all]
  multiagent rename --session NAME --to NEW_NAME
  multiagent [--session NAME] [--workspace PATH] [--detach] [--fresh] [--no-auto] [--agents AGENT_LIST] [--log-dir PATH] [--install]

Creates a tmux session where window 0 is reserved for the human terminal,
and each agent gets its own tmux window.

Options:
  --agents AGENT_LIST  Comma-separated list of agents to launch (default: all)
                       Available: $ALL_AGENTS_DISPLAY
                       Examples:
                         --agents claude,gemini
                         --agents claude,codex,copilot

  --user-pane SPEC     Add short terminal panes for the human operator (default: bottom:1)
                       Examples: top, bottom:2, top:2,bottom:1, none

  --log-dir PATH       Directory to save pane output logs (default: WORKSPACE/logs)
                       Each session creates timestamped log files per agent.
                       Set to empty string to disable logging.

  --session NAME       Name of the tmux session (default: current directory name)
  --workspace PATH     Working directory (default: current directory)
  --detach             Start session in detached mode
  --fresh              Delete existing logs for the session name before starting
  --no-auto            Disable auto-mode (auto-mode is ON by default)
  --all                For list: include archived sessions. For status/kill: target all active sessions
  --latest             Target the most recently created session for this multiagent install
  --to NEW_NAME        New session name for rename
  --verbose            Show extra details in list output
  --install            Create symlinks in ~/.local/bin for multiagent,
                       agent-index, and agent-send so they can be run from anywhere
  list                 List active sessions for this multiagent install
  context              Print session/workspace/agent-pane summary for the current pane (or --session)
  brief                Send the agent communication briefing manually
  add-agent            Add a new agent to an existing session
  remove-agent         Remove one agent pane (INSTANCE e.g. claude, gemini-2); chat jsonl is untouched
  save                 Save pane logs for an existing session
  refresh-save-hooks   Rewrite /tmp/multiagent_save_*.sh and tmux hooks for all active repo sessions
  status               Show session status without starting or changing anything
  resume               Attach to an existing session without creating a new one
  kill                 Kill an existing session explicitly
  rename               Rename an existing session explicitly
EOF
}

list_sessions() {
  local found=0 session active_sessions=""
  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    active_sessions="${active_sessions}"$'\n'"${session}"
    if [[ "$LIST_VERBOSE" -eq 1 ]]; then
      printf 'Session: %s\n' "$session"
      printf '  Status: %s\n' "$(session_status_summary "$session")"
      printf '  Running: yes\n'
      printf '  Workspace: %s\n' "$(session_workspace_value "$session")"
      printf '  Bin dir: %s\n' "$(session_bin_dir_value "$session")"
      printf '  Windows: %s\n' "$(session_window_count "$session")"
      printf '  Panes: %s\n' "$(session_pane_count "$session")"
      printf '  Dead panes: %s\n' "$(session_dead_pane_count "$session")"
      printf '  Attached clients: %s\n' "$(session_attached_value "$session")"
      if [[ -n "$(session_user_pane_value "$session")" ]]; then
        printf '  User pane: %s\n' "$(session_user_pane_value "$session")"
      fi
      printf '  Agents: %s\n' "$(session_agents_value "$session")"
      printf '  Created: %s\n' "$(session_created_value "$session")"
      printf '%s\n' "$(session_agent_state_lines "$session")"
      echo
    else
      printf '%s\tstatus=%s\trunning=yes\tpanes=%s\tagents=%s\tcreated=%s\n' \
        "$session" \
        "$(session_status_summary "$session")" \
        "$(session_pane_count "$session")" \
        "$(session_agents_value "$session")" \
        "$(session_created_value "$session")"
    fi
    found=1
  done < <(repo_sessions)

  if [[ "$ALL_SESSIONS" -eq 1 ]]; then
    local archived_session archived_workspace archived_created archived_updated archived_agents archived_log_dir
    while IFS=$'\t' read -r archived_session archived_workspace archived_created archived_updated archived_agents archived_log_dir; do
      [[ -n "$archived_session" ]] || continue
      if printf '%s\n' "$active_sessions" | grep -Fqx "$archived_session"; then
        continue
      fi
      if [[ "$LIST_VERBOSE" -eq 1 ]]; then
        printf 'Session: %s\n' "$archived_session"
        printf '  Status: archived\n'
        printf '  Running: no\n'
        [[ -n "$archived_workspace" && "$archived_workspace" != "-" ]] && printf '  Workspace: %s\n' "$archived_workspace"
        printf '  Log dir: %s\n' "$archived_log_dir"
        printf '  Agents: %s\n' "$archived_agents"
        [[ -n "$archived_created" ]] && printf '  Created: %s\n' "$archived_created"
        [[ -n "$archived_updated" ]] && printf '  Updated: %s\n' "$archived_updated"
        echo
      else
        printf '%s\tstatus=archived\trunning=no\tagents=%s\tcreated=%s\tupdated=%s\tlog_dir=%s\n' \
          "$archived_session" \
          "$archived_agents" \
          "$archived_created" \
          "$archived_updated" \
          "$archived_log_dir"
      fi
      found=1
    done < <(archived_repo_sessions)
  fi

  [[ "$found" -eq 1 ]] || echo "No sessions found for this multiagent install"
}

show_status() {
  local session="$1"
  if ! tmux has-session -t "=$session" 2>/dev/null; then
    echo "Session not found: $session"
    return 0
  fi

  local workspace bin_dir window_count pane_count user_pane
  workspace="$(tmux show-environment -t "$session" MULTIAGENT_WORKSPACE 2>/dev/null | sed 's/^[^=]*=//')"
  bin_dir="$(tmux show-environment -t "$session" MULTIAGENT_BIN_DIR 2>/dev/null | sed 's/^[^=]*=//')"
  window_count="$(tmux list-windows -t "$session" 2>/dev/null | wc -l | tr -d ' ')"
  pane_count="$(tmux list-panes -s -t "$session" 2>/dev/null | wc -l | tr -d ' ')"
  user_pane="$(session_user_pane_value "$session")"

  echo "Session: $session"
  echo "Running: yes"
  [[ -n "$workspace" ]] && echo "Workspace: $workspace"
  [[ -n "$bin_dir" ]] && echo "Bin dir: $bin_dir"
  echo "Windows: $window_count"
  echo "Panes: $pane_count"
  [[ -n "$user_pane" ]] && echo "User pane: $user_pane"
  echo "Agents:"

  local instance upper pane_id pane_title pane_dead agents_str
  agents_str="$(session_agents_value "$session")"
  [[ "$agents_str" == "-" ]] && agents_str="$ALL_AGENTS_CSV"
  IFS=',' read -ra _status_agents <<< "$agents_str"
  for instance in "${_status_agents[@]}"; do
    upper="$(printf '%s' "$instance" | tr '[:lower:]-' '[:upper:]_')"
    pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    if [[ -z "$pane_id" ]]; then
      echo "  - $instance: not configured"
      continue
    fi
    pane_title="$(tmux display-message -p -t "$pane_id" '#{pane_title}' 2>/dev/null || true)"
    pane_dead="$(tmux display-message -p -t "$pane_id" '#{pane_dead}' 2>/dev/null || true)"
    if [[ "$pane_dead" == "1" ]]; then
      echo "  - $instance: pane=$pane_id dead"
    else
      echo "  - $instance: pane=$pane_id title=${pane_title:-unknown} running"
    fi
  done
}

print_agent_context() {
  local session="$1" resolved_note="$2"
  local workspace bin_dir log_dir agents_str inst upper pane_id pane_title pane_dead pane_cmd
  local current_pane instance_guess user_panes_csv sock

  workspace="$(tmux show-environment -t "$session" MULTIAGENT_WORKSPACE 2>/dev/null | sed 's/^[^=]*=//' || true)"
  bin_dir="$(tmux show-environment -t "$session" MULTIAGENT_BIN_DIR 2>/dev/null | sed 's/^[^=]*=//' || true)"
  log_dir="$(tmux show-environment -t "$session" MULTIAGENT_LOG_DIR 2>/dev/null | sed 's/^[^=]*=//' || true)"
  sock="$(tmux show-environment -t "$session" MULTIAGENT_TMUX_SOCKET 2>/dev/null | sed 's/^[^=]*=//' || true)"
  [[ -z "$sock" ]] && sock="$TMUX_SOCKET_NAME"
  agents_str="$(session_agents_value "$session")"
  [[ "$agents_str" == "-" ]] && agents_str=""

  current_pane="${TMUX_PANE:-}"
  instance_guess=""
  if [[ -n "$current_pane" && -n "$agents_str" ]]; then
    IFS=',' read -ra _ctx_agents <<< "$agents_str"
    for inst in "${_ctx_agents[@]}"; do
      [[ -n "$inst" ]] || continue
      upper="$(printf '%s' "$inst" | tr '[:lower:]-' '[:upper:]_')"
      pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
      [[ "$pane_id" == "$current_pane" ]] && instance_guess="$inst" && break
    done
  fi
  [[ -n "$instance_guess" ]] || instance_guess="${MULTIAGENT_AGENT_NAME:-}"
  user_panes_csv="$(session_user_pane_value "$session")"
  if [[ -z "$instance_guess" && -n "$current_pane" && -n "$user_panes_csv" ]]; then
    case ",${user_panes_csv}," in
      *,"${current_pane}",*) instance_guess="(user/terminal pane)" ;;
    esac
  fi

  if [[ "$CONTEXT_JSON" -eq 1 ]]; then
    python3 - "$session" "$resolved_note" "$sock" "${MULTIAGENT_SESSION:-}" "$workspace" "$bin_dir" "$log_dir" \
      "$agents_str" "$current_pane" "$instance_guess" "$user_panes_csv" "$CENTRAL_LOG_DIR" <<'PYEOF'
import json
import os
import sys

session, resolved_note, sock, mult_session, workspace, bin_dir, log_dir = sys.argv[1:8]
agents_str, current_pane, instance_guess, user_panes_csv, central_log = sys.argv[8:13]

agents = [a.strip() for a in agents_str.split(",") if a.strip()] if agents_str else []
out = {
    "tmux_session": session,
    "session_resolved_via": resolved_note or None,
    "tmux_socket_effective": sock or None,
    "MULTIAGENT_SESSION_env": mult_session or None,
    "workspace": workspace or None,
    "MULTIAGENT_BIN_DIR": bin_dir or None,
    "MULTIAGENT_LOG_DIR": log_dir or None,
    "central_log_repo": central_log or None,
    "MULTIAGENT_AGENTS": agents,
    "current_tmux_pane": current_pane or None,
    "this_pane_role": instance_guess or None,
    "user_panes_env_csv": user_panes_csv or None,
}
print(json.dumps(out, indent=2, ensure_ascii=False))
PYEOF
    return 0
  fi

  printf '%s\n' "## multiagent context"
  printf '%s\n' ""
  printf '%s\n' "- **tmux session**: ${session}"
  printf '%s\n' "- **session resolved via**: ${resolved_note:-unknown}"
  printf '%s\n' "- **tmux socket (effective)**: ${sock}"
  [[ -n "${MULTIAGENT_SESSION:-}" ]] && printf '%s\n' "- **MULTIAGENT_SESSION (env)**: ${MULTIAGENT_SESSION}"
  [[ -n "$workspace" ]] && printf '%s\n' "- **MULTIAGENT_WORKSPACE**: ${workspace}"
  [[ -n "$bin_dir" ]] && printf '%s\n' "- **MULTIAGENT_BIN_DIR**: ${bin_dir}"
  [[ -n "$log_dir" ]] && printf '%s\n' "- **MULTIAGENT_LOG_DIR**: ${log_dir}"
  printf '%s\n' "- **repo central logs**: ${CENTRAL_LOG_DIR}"
  printf '%s\n' "- **MULTIAGENT_AGENTS**: ${agents_str:-<unset>}"
  [[ -n "$current_pane" ]] && printf '%s\n' "- **this tmux pane (TMUX_PANE)**: ${current_pane}"
  [[ -n "$instance_guess" ]] && printf '%s\n' "- **this pane as agent instance (best effort)**: ${instance_guess}"
  [[ -n "$user_panes_csv" ]] && printf '%s\n' "- **user panes (env csv)**: ${user_panes_csv}"
  printf '%s\n' ""
  printf '%s\n' "### Agent panes"
  if [[ -n "$agents_str" ]]; then
    session_agent_state_lines "$session"
  else
    printf '%s\n' "  (MULTIAGENT_AGENTS unset and no fallback; use \`multiagent status --session '${session}'\`.)"
  fi
  printf '%s\n' ""
  printf '%s\n' "### Hints"
  printf '%s\n' "- \`agent-send\` uses \`MULTIAGENT_SESSION\` (and tmux); targets come from MULTIAGENT_AGENTS and MULTIAGENT_PANE_* in this session."
  printf '%s\n' "- Chat jsonl usually lives under **MULTIAGENT_LOG_DIR** / \`<workspace>/logs/<session>/\` (see your layout)."
}

send_text_to_pane() {
  local pane_id="$1" payload="$2"
  tmux set-buffer -- "$payload"
  tmux paste-buffer -d -t "$pane_id"
  sleep 0.3
  tmux send-keys -t "$pane_id" "" Enter
}

wait_for_agent_ready() {
  local pane_id="$1" agent_name="$2" max_attempts=120 attempt current_command pane_text ready_pattern
  local _base="${agent_name%%-[0-9]*}"
  ready_pattern="$(agent_var AGENT_READY_PATTERN "$_base")"
  for (( attempt=0; attempt<max_attempts; attempt++ )); do
    current_command="$(tmux display-message -p -t "$pane_id" '#{pane_current_command}' 2>/dev/null || true)"
    pane_text="$(tmux capture-pane -p -S -40 -t "$pane_id" 2>/dev/null || true)"
    if [[ -n "$ready_pattern" ]] && printf '%s\n' "$pane_text" | grep -Eq "$ready_pattern"; then
      return 0
    fi
    case "$current_command" in
      bash|zsh|sh|login) sleep 0.5 ;;
      "") sleep 0.5 ;;
      *) sleep 0.5 ;;
    esac
  done
  return 0
}

wait_for_user_pane_ready() {
  local pane_id="$1" max_attempts="${2:-80}" attempt current_command pane_text
  for (( attempt=0; attempt<max_attempts; attempt++ )); do
    current_command="$(tmux display-message -p -t "$pane_id" '#{pane_current_command}' 2>/dev/null || true)"
    pane_text="$(tmux capture-pane -p -S -20 -t "$pane_id" 2>/dev/null || true)"
    if [[ "$current_command" =~ ^(bash|zsh|sh|login)$ ]] && printf '%s\n' "$pane_text" | grep -Fq '[multiagent] shortcuts:'; then
      return 0
    fi
    sleep 0.25
  done
  return 0
}

open_chat_in_user_pane() {
  local pane_id="$1"
  [[ -n "$pane_id" ]] || return 0
  [[ "${MULTIAGENT_SKIP_USER_CHAT:-0}" == "1" ]] && return 0
  wait_for_user_pane_ready "$pane_id"
  send_text_to_pane "$pane_id" "follow --chat"
}

send_agent_capability_briefing() {
  local pane_id="$1" agent_name="$2" briefing
  printf -v briefing '%s\n' \
    "Multiagent session note for ${agent_name}:" \
    "- You are running inside a tmux-based multiagent session. agent-send targets other agent panes in this session." \
    "- agent-send is for agent-to-agent communication only. Send the body on stdin. Example: printf '%s' 'hello' | agent-send claude" \
    "- To inspect message history, use: agent-index or agent-index --agent <name>. Do NOT run agent-index --follow — it blocks forever and will hang your pane." \
    "- For messages to the human/chat, respond in your normal assistant output in this pane. Native event logs are indexed directly." \
    "- Messages sent via agent-send are displayed in the chat UI (agent-index --chat) with Markdown rendering. You may use Markdown in your messages: **bold**, \`inline code\`, \`\`\`code blocks\`\`\`, headers, lists, tables, etc." \
    "- The chat UI also renders LaTeX math via KaTeX. Use \$...\$ for inline math and \$\$...\$\$ for display (block) math. Standard LaTeX commands and environments such as cases, pmatrix, bmatrix, align, aligned, and array are generally supported." \
    "- The chat UI renders Mermaid diagrams. Use \`\`\`mermaid code blocks to create flowcharts, sequence diagrams, class diagrams, state diagrams, ER diagrams, Gantt charts, etc. They are rendered as interactive SVG graphics. Example: \`\`\`mermaid\\ngraph TD\\n    A[Start] --> B[End]\\n\`\`\`" \
    "- To attach a file reference in your message, include [Attached: path/to/file] anywhere in the text. The chat UI will render it as a clickable file card. Example: printf '%s' 'Here is the result [Attached: src/main.py]' | agent-send claude" \
    "- For agent-to-agent collaboration, use agent-send so the handoff is visible in chat history." \
    "- Agent-to-agent messages must contain actual content. Do not send a single-word message unless explicitly asked." \
    "- Do not start greeting loops or casual chatter unless explicitly instructed." \
    "- For normal chat messages to the human, do not run agent-send; answer directly in your assistant output." \
    "- To confirm you have read this briefing, respond in your normal assistant output with exactly: Briefing received."
  send_text_to_pane "$pane_id" "$briefing"
}

brief_session_agents() {
  local session="$1" requested_agents="${2:-}" agent base_agent upper pane_id
  local selected_agents=()
  if [[ -n "$requested_agents" ]]; then
    IFS=',' read -r -a selected_agents <<< "$requested_agents"
  else
    # Read MULTIAGENT_AGENTS; fall back to default set
    local agents_str
    agents_str="$(tmux show-environment -t "$session" MULTIAGENT_AGENTS 2>/dev/null | sed 's/^[^=]*=//' || true)"
    if [[ -n "$agents_str" ]]; then
      IFS=',' read -r -a selected_agents <<< "$agents_str"
    else
      selected_agents=("${ALL_AGENTS[@]}")
    fi
  fi
  for agent in "${selected_agents[@]}"; do
    # Strip instance suffix to get base agent name for validation
    base_agent="${agent%%-[0-9]*}"
    if ! agent_in_registry "$base_agent"; then
      echo "Unknown agent for brief: $agent" >&2
      return 1
    fi
    upper="$(printf '%s' "$agent" | tr '[:lower:]-' '[:upper:]_')"
    pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    [[ -n "$pane_id" ]] || continue
    send_agent_capability_briefing "$pane_id" "$agent"
  done
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    list)        MODE="list"; shift ;;
    context)     MODE="context"; shift ;;
    brief)       MODE="brief"; shift ;;
    add-agent)   MODE="add-agent"; shift ;;
    remove-agent) MODE="remove-agent"; shift ;;
    save)        MODE="save"; shift ;;
    refresh-save-hooks) MODE="refresh-save-hooks"; shift ;;
    status)      MODE="status"; shift ;;
    resume)      MODE="resume"; shift ;;
    kill)        MODE="kill"; shift ;;
    rename)      MODE="rename"; shift ;;
    --session)   SESSION_NAME="$2"; SESSION_NAME_EXPLICIT=1; shift 2 ;;
    --workspace) WORKSPACE="$2"; shift 2 ;;
    --detach)    DETACH=1; shift ;;
    --fresh)     FRESH=1; shift ;;
    --no-auto)   AUTO=0; shift ;;
    --all)       ALL_SESSIONS=1; shift ;;
    --latest)    LATEST_SESSION=1; shift ;;
    --to)        RENAME_TO="$2"; shift 2 ;;
    --verbose)   LIST_VERBOSE=1; shift ;;
    --json)      CONTEXT_JSON=1; shift ;;
    --agents|--agent) AGENTS_ARG="$2"; shift 2 ;;
    --layout)    echo "Warning: --layout is deprecated; grid is always used" >&2; shift 2 ;;
    --user-pane) USER_PANE="$2"; shift 2 ;;
    --log-dir)   LOG_DIR="$2"; shift 2 ;;
    --install)   INSTALL=1; shift ;;
    -h|--help)   usage; exit 0 ;;
    *)           echo "Unknown argument: $1" >&2; usage >&2; exit 1 ;;
  esac
done

WORKSPACE="$(cd "$WORKSPACE" && pwd)"
if [[ -z "$SESSION_NAME" ]] && [[ "$MODE" == "up" ]]; then
  SESSION_NAME="$(default_session_name)"
fi

if [[ "$ALL_SESSIONS" -eq 1 ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 1 ]]; then
  echo "Cannot combine --all with --session" >&2
  exit 1
fi

if [[ "$LATEST_SESSION" -eq 1 ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 1 ]]; then
  echo "Cannot combine --latest with --session" >&2
  exit 1
fi

if [[ "$ALL_SESSIONS" -eq 1 ]] && [[ "$LATEST_SESSION" -eq 1 ]]; then
  echo "Cannot combine --all with --latest" >&2
  exit 1
fi

if [[ "$MODE" == "status" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  if [[ "$ALL_SESSIONS" -eq 1 ]]; then
    found=0
    while IFS= read -r session; do
      [[ -z "$session" ]] && continue
      show_status "$session"
      echo
      found=1
    done < <(repo_sessions)
    [[ "$found" -eq 1 ]] || echo "No sessions found for this multiagent install"
    exit 0
  fi
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  show_status "$SESSION_NAME"
  exit 0
fi

if [[ "$MODE" == "context" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  resolved_note=""
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    if [[ -n "${MULTIAGENT_SESSION:-}" ]]; then
      SESSION_NAME="$MULTIAGENT_SESSION"
    elif [[ -n "${MULTIAGENT_SESSION_NAME:-}" ]]; then
      SESSION_NAME="$MULTIAGENT_SESSION_NAME"
    fi
  fi
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    if [[ -n "${TMUX:-}" ]]; then
      SESSION_NAME="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
    fi
  fi
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist or could not be resolved (set MULTIAGENT_SESSION or run inside tmux)." >&2
    exit 1
  fi
  if ! tmux has-session -t "=$SESSION_NAME" 2>/dev/null; then
    echo "tmux session not found: $SESSION_NAME" >&2
    exit 1
  fi
  if [[ "$SESSION_NAME_EXPLICIT" -eq 1 ]]; then
    resolved_note="--session"
  elif [[ -n "${MULTIAGENT_SESSION:-}" && "$SESSION_NAME" == "${MULTIAGENT_SESSION}" ]]; then
    resolved_note="MULTIAGENT_SESSION"
  elif [[ -n "${MULTIAGENT_SESSION_NAME:-}" && "$SESSION_NAME" == "${MULTIAGENT_SESSION_NAME}" ]]; then
    resolved_note="MULTIAGENT_SESSION_NAME"
  elif [[ -n "${TMUX:-}" ]]; then
    resolved_note="tmux client (#{session_name})"
  else
    resolved_note="resolve_target_session_name"
  fi
  print_agent_context "$SESSION_NAME" "$resolved_note"
  exit 0
fi

if [[ "$MODE" == "list" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  list_sessions
  exit 0
fi

if [[ "$MODE" == "brief" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "=$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi
  brief_session_agents "$SESSION_NAME" "$AGENTS_ARG"
  if [[ -n "$AGENTS_ARG" ]]; then
    echo "Sent briefing to agents ($AGENTS_ARG) in session: $SESSION_NAME"
  else
    echo "Sent briefing to agents in session: $SESSION_NAME"
  fi
  exit 0
fi

if [[ "$MODE" == "save" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "=$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi
  hook_script="/tmp/multiagent_save_${SESSION_NAME}.sh"
  if [[ -x "$hook_script" ]]; then
    "$hook_script" save || true
    echo "Saved logs for session: $SESSION_NAME"
  else
    echo "No save hook found for session: $SESSION_NAME (logging may be disabled)" >&2
    exit 1
  fi
  exit 0
fi

if [[ "$MODE" == "refresh-save-hooks" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  found=0
  while IFS= read -r _r_session; do
    [[ -z "$_r_session" ]] && continue
    _r_log="$(tmux show-environment -t "$_r_session" MULTIAGENT_LOG_DIR 2>/dev/null | sed 's/^[^=]*=//' || true)"
    if [[ -z "$_r_log" ]]; then
      echo "[multiagent] skip ${_r_session} (logging disabled)" >&2
      continue
    fi
    _r_ws="$(tmux show-environment -t "$_r_session" MULTIAGENT_WORKSPACE 2>/dev/null | sed 's/^[^=]*=//' || true)"
    [[ -z "$_r_ws" || "$_r_ws" == "-" ]] && _r_ws="$WORKSPACE"
    _r_sock="$(tmux show-environment -t "$_r_session" MULTIAGENT_TMUX_SOCKET 2>/dev/null | sed 's/^[^=]*=//' || true)"
    [[ -z "$_r_sock" ]] && _r_sock="$TMUX_SOCKET_NAME"
    emit_session_save_hook "$_r_session" "$_r_log" "$_r_ws" "$_r_sock"
    echo "[multiagent] refreshed save hooks for session: ${_r_session}" >&2
    found=1
  done < <(repo_sessions)
  [[ "$found" -eq 1 ]] || echo "No active sessions for this multiagent install" >&2
  exit 0
fi

if [[ "$MODE" == "resume" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "=$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi
  # Restart auto-mode monitor if it was on but the process has died
  _auto_val="$(tmux show-environment -t "$SESSION_NAME" MULTIAGENT_AUTO_MODE 2>/dev/null | sed 's/^[^=]*=//' || echo "0")"
  if [[ "$_auto_val" == "1" ]]; then
    _pid_file="/tmp/multiagent_auto_${SESSION_NAME}.pid"
    _pid="$(cat "$_pid_file" 2>/dev/null || true)"
    if [[ -z "$_pid" ]] || ! kill -0 "$_pid" 2>/dev/null; then
      "$SCRIPT_DIR/multiagent-auto-mode" on --session "$SESSION_NAME" >&2 || true
    fi
  fi
  [[ "$DETACH" -eq 1 ]] && { echo "Session exists: $SESSION_NAME"; exit 0; }
  open_chat_in_user_pane "$(primary_user_pane_id "$SESSION_NAME")"
  exec_tmux attach-session -t "$SESSION_NAME"
fi

if [[ "$MODE" == "kill" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  if [[ "$ALL_SESSIONS" -eq 1 ]]; then
    killed=0
    while IFS= read -r session; do
      [[ -z "$session" ]] && continue
      if ! stop_session_chat_server "$session"; then
        echo "[multiagent] warning: failed to stop chat server for $session" >&2
      fi
      hook_script="/tmp/multiagent_save_${session}.sh"
      [[ -x "$hook_script" ]] && "$hook_script" kill || true
      rm -f "$(multiagent_panes_state_path)" 2>/dev/null || true
      tmux kill-session -t "$session"
      echo "Killed tmux session: $session"
      killed=1
    done < <(repo_sessions)
    [[ "$killed" -eq 1 ]] || { echo "No sessions found for this multiagent install"; exit 1; }
    exit 0
  fi
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "=$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi
  if ! stop_session_chat_server "$SESSION_NAME"; then
    echo "[multiagent] warning: failed to stop chat server for $SESSION_NAME" >&2
  fi
  hook_script="/tmp/multiagent_save_${SESSION_NAME}.sh"
  [[ -x "$hook_script" ]] && "$hook_script" kill || true
  rm -f "$(multiagent_panes_state_path)" 2>/dev/null || true
  tmux kill-session -t "$SESSION_NAME"
  echo "Killed tmux session: $SESSION_NAME"
  exit 0
fi

if [[ "$MODE" == "rename" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  [[ -n "$RENAME_TO" ]] || { echo "rename requires --to NEW_NAME" >&2; exit 1; }
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "=$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi
  if tmux has-session -t "=$RENAME_TO" 2>/dev/null; then
    echo "Session already exists: $RENAME_TO" >&2
    exit 1
  fi
  tmux rename-session -t "$SESSION_NAME" "$RENAME_TO"
  echo "Renamed tmux session: $SESSION_NAME -> $RENAME_TO"
  exit 0
fi

parse_user_pane_spec "$USER_PANE" || {
  echo "Unknown --user-pane value: $USER_PANE (examples: none, top, bottom:2, top:2,bottom:1)" >&2
  exit 1
}

# --- Install symlinks to ~/.local/bin ---
if [[ "$INSTALL" -eq 1 ]]; then
  INSTALL_DIR="${MULTIAGENT_INSTALL_DIR:-$HOME/.local/bin}"
  mkdir -p "$INSTALL_DIR"
  for cmd in multiagent agent-index agent-send; do
    src="$SCRIPT_DIR/$cmd"
    dst="$INSTALL_DIR/$cmd"
    if [[ -e "$dst" ]] && [[ "$(readlink "$dst" 2>/dev/null)" == "$src" ]]; then
      echo "Already installed: $dst -> $src"
    else
      ln -sf "$src" "$dst"
      echo "Installed: $dst -> $src"
    fi
  done
  echo "Done. Make sure $INSTALL_DIR is in your PATH."
  exit 0
fi

# --- Resolve which agents to launch ---
if [[ -n "$AGENTS_ARG" ]]; then
  IFS=',' read -ra SELECTED_AGENTS <<< "$AGENTS_ARG"
  # Validate and normalise: strip instance suffixes (claude-1 → claude) so
  # the downstream instance-name generator handles numbering uniformly.
  _normalised=()
  for agent in "${SELECTED_AGENTS[@]}"; do
    base_agent="${agent%%-[0-9]*}"
    valid=0
    for a in "${ALL_AGENTS[@]}"; do
      [[ "$base_agent" == "$a" ]] && valid=1 && break
    done
    if [[ "$valid" -eq 0 ]]; then
      echo "Unknown agent: $agent (available: ${ALL_AGENTS[*]})" >&2
      exit 1
    fi
    _normalised+=("$base_agent")
  done
  SELECTED_AGENTS=("${_normalised[@]}")
else
  SELECTED_AGENTS=("${ALL_AGENTS[@]}")
fi

if [[ ${#SELECTED_AGENTS[@]} -lt 1 ]]; then
  echo "At least one agent must be specified." >&2
  exit 1
fi

# --- Generate instance names ---
# If an agent appears more than once, suffix with -1, -2, etc.
# e.g., claude,claude,gemini → claude-1,claude-2,gemini
_instance_names_str="$(python3 -c "
import sys
agents = sys.argv[1:]
from collections import Counter
counts = Counter(agents)
indices = {}
result = []
for a in agents:
    if counts[a] > 1:
        indices[a] = indices.get(a, 0) + 1
        result.append(f'{a}-{indices[a]}')
    else:
        result.append(a)
print(','.join(result))
" "${SELECTED_AGENTS[@]}")"
IFS=',' read -ra INSTANCE_NAMES <<< "$_instance_names_str"

if [[ "${MULTIAGENT_SKIP_AGENT_CLI_INSTALL:-}" != "1" ]] && [[ -f "$SCRIPT_DIR/ensure-multiagent-agent-clis" ]]; then
  bash "$SCRIPT_DIR/ensure-multiagent-agent-clis" --interactive "${SELECTED_AGENTS[@]}" || exit 1
fi

if [[ "${MULTIAGENT_STRICT_AGENT_CLIS:-}" != "1" ]]; then
  _kept=()
  for agent in "${SELECTED_AGENTS[@]}"; do
    if resolve_agent_executable "$agent" >/dev/null; then
      _kept+=("$agent")
    else
      echo "multiagent: 警告: ${agent} の CLI が無いため起動しません（厳格にするには MULTIAGENT_STRICT_AGENT_CLIS=1）" >&2
    fi
  done
  SELECTED_AGENTS=("${_kept[@]}")
  if [[ ${#SELECTED_AGENTS[@]} -lt 1 ]]; then
    echo "multiagent: 起動できるエージェントがありません。CLI を入れるか --agents で指定してください。" >&2
    exit 1
  fi
  _instance_names_str="$(python3 -c "
import sys
agents = sys.argv[1:]
from collections import Counter
counts = Counter(agents)
indices = {}
result = []
for a in agents:
    if counts[a] > 1:
        indices[a] = indices.get(a, 0) + 1
        result.append(f'{a}-{indices[a]}')
    else:
        result.append(a)
print(','.join(result))
" "${SELECTED_AGENTS[@]}")"
  IFS=',' read -ra INSTANCE_NAMES <<< "$_instance_names_str"
fi

command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
# Check that each unique base agent command exists
_checked_cmds=""
for agent in "${SELECTED_AGENTS[@]}"; do
  case ",$_checked_cmds," in
    *,"$agent",*) ;;
    *)
      check_cmd="$(resolve_agent_executable "$agent")" || {
        check_cmd="$(agent_var AGENT_EXECUTABLE "$agent")"
        [[ -n "$check_cmd" ]] || check_cmd="$agent"
        echo "Required command not found: $check_cmd" >&2
        echo "  （CLI を入れるか、MULTIAGENT_STRICT_AGENT_CLIS を付けない場合は未導入分は起動しません）" >&2
        exit 1
      }
      _checked_cmds="${_checked_cmds:+$_checked_cmds,}$agent"
      ;;
  esac
done

# --- Save logs from a session ---
# Layout:
#   <base>/<session>/*.ans|*.log
#   <base>/<session>/.meta
# Detailed timestamps and overwrite history are stored in .meta.
_session_log_dir() {
  local session="$1" base_dir="$2"
  local created_epoch created_at updated_at old_dir session_dir
  created_epoch="$(tmux display-message -p -t "$session" '#{session_created}' 2>/dev/null || true)"
  if [[ -n "$created_epoch" ]]; then
    created_at="$(date -r "$created_epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date '+%Y-%m-%d %H:%M:%S')"
  else
    created_at="$(date '+%Y-%m-%d %H:%M:%S')"
  fi
  updated_at="$(date '+%Y-%m-%d %H:%M:%S')"
  mkdir -p "$base_dir"
  session_dir="${base_dir}/${session}"
  if [[ ! -d "$session_dir" ]]; then
    old_dir="$(find "$base_dir" -maxdepth 1 -type d -name "${session}_*" 2>/dev/null | sort | tail -n 1)"
    if [[ -n "$old_dir" ]] && [[ "$old_dir" != "$session_dir" ]]; then
      mv "$old_dir" "$session_dir"
    else
      mkdir -p "$session_dir"
    fi
  else
    mkdir -p "$session_dir"
  fi
  printf '%s\t%s\t%s\n' "$session_dir" "$created_at" "$updated_at"
}

_canonical_session_log_dir() {
  local session="$1"
  printf '%s/%s\n' "$CENTRAL_LOG_DIR" "$session"
}

_canonical_session_index_path() {
  local session="$1"
  printf '%s/.agent-index.jsonl\n' "$(_canonical_session_log_dir "$session")"
}

_ensure_canonical_index_healthy() {
  local session="$1" canonical_index
  canonical_index="$(_canonical_session_index_path "$session")"
  python3 - "$canonical_index" <<'PYEOF'
import os
import shutil
import sys
from pathlib import Path

canonical = Path(sys.argv[1])
canonical.parent.mkdir(parents=True, exist_ok=True)
canonical_abs = canonical.resolve().as_posix() if canonical.exists() else canonical.absolute().as_posix()

def _target_abs(path: Path) -> str:
    target = os.readlink(path)
    if os.path.isabs(target):
        return os.path.abspath(target)
    return os.path.abspath(path.parent / target)

if canonical.is_symlink():
    try:
        if _target_abs(canonical) == os.path.abspath(canonical):
            canonical.unlink()
    except Exception:
        try:
            canonical.unlink()
        except Exception:
            pass

if not canonical.exists():
    backups = sorted(
        canonical.parent.glob(".agent-index.jsonl.backup.*"),
        key=lambda p: p.stat().st_mtime,
    )
    if backups:
        shutil.copy2(backups[-1], canonical)
    else:
        bak = canonical.parent / ".agent-index.jsonl.bak"
        if bak.exists():
            shutil.copy2(bak, canonical)
        else:
            canonical.touch()
PYEOF
}

_merge_index_jsonl_into_canonical() {
  local canonical_path="$1" source_path="$2"
  python3 - "$canonical_path" "$source_path" <<'PYEOF'
import fcntl
import json
import os
import sys

canonical_path, source_path = sys.argv[1:3]
if not os.path.isfile(source_path):
    raise SystemExit(0)

os.makedirs(os.path.dirname(canonical_path), exist_ok=True)
with open(canonical_path, "a+", encoding="utf-8") as canonical:
    fcntl.flock(canonical.fileno(), fcntl.LOCK_EX)
    canonical.seek(0)
    existing_lines = canonical.read().splitlines()
    seen_ids = set()
    seen_raw = set()
    for line in existing_lines:
        raw = line.strip()
        if not raw:
            continue
        seen_raw.add(raw)
        try:
            msg_id = str((json.loads(raw) or {}).get("msg_id") or "").strip()
        except Exception:
            msg_id = ""
        if msg_id:
            seen_ids.add(msg_id)

    appended = []
    with open(source_path, "r", encoding="utf-8", errors="replace") as source:
        for line in source:
            raw = line.strip()
            if not raw:
                continue
            try:
                item = json.loads(raw)
            except Exception:
                if raw in seen_raw:
                    continue
                seen_raw.add(raw)
                appended.append(raw)
                continue
            msg_id = str((item or {}).get("msg_id") or "").strip()
            if msg_id:
                if msg_id in seen_ids:
                    continue
                seen_ids.add(msg_id)
            elif raw in seen_raw:
                continue
            seen_raw.add(raw)
            appended.append(raw)

    if appended:
        canonical.seek(0, os.SEEK_END)
        for raw in appended:
            canonical.write(raw + "\n")
        canonical.flush()
    fcntl.flock(canonical.fileno(), fcntl.LOCK_UN)
PYEOF
}

ensure_session_index_mirror_at_base() {
  local session="$1" base_dir="$2"
  local canonical_index canonical_real canonical_abs alias_dir alias_index alias_abs alias_backup alias_target base_real central_real
  [[ -n "$base_dir" ]] || return 0
  canonical_index="$(_canonical_session_index_path "$session")"
  _ensure_canonical_index_healthy "$session"
  mkdir -p "$(dirname "$canonical_index")"
  touch "$canonical_index"
  canonical_real="$(realpath_or_echo "$canonical_index")"
  canonical_abs="$(python3 -c 'import os,sys; print(os.path.abspath(sys.argv[1]))' "$canonical_index" 2>/dev/null || printf '%s' "$canonical_index")"
  base_real="$(realpath_or_echo "$base_dir")"
  central_real="$(realpath_or_echo "$CENTRAL_LOG_DIR")"
  [[ "$base_real" == "$central_real" ]] && return 0

  alias_dir="${base_dir}/${session}"
  alias_index="${alias_dir}/.agent-index.jsonl"
  alias_abs="$(python3 -c 'import os,sys; print(os.path.abspath(sys.argv[1]))' "$alias_index" 2>/dev/null || printf '%s' "$alias_index")"
  [[ "$alias_abs" == "$canonical_abs" ]] && return 0
  mkdir -p "$alias_dir"

  if [[ -L "$alias_index" ]]; then
    alias_target="$(realpath_or_echo "$alias_index")"
    if [[ "$alias_target" == "$canonical_real" ]]; then
      return 0
    fi
    rm -f "$alias_index"
  elif [[ -f "$alias_index" ]]; then
    _merge_index_jsonl_into_canonical "$canonical_index" "$alias_index" || true
    alias_backup="${alias_index}.backup.$(date +%Y%m%d_%H%M%S)"
    mv "$alias_index" "$alias_backup" 2>/dev/null || rm -f "$alias_index"
  elif [[ -e "$alias_index" ]]; then
    return 0
  fi

  ln -s "$canonical_index" "$alias_index" 2>/dev/null || true
}

ensure_session_index_mirrors() {
  local session="$1"
  local canonical_index
  canonical_index="$(_canonical_session_index_path "$session")"
  mkdir -p "$(dirname "$canonical_index")"
  touch "$canonical_index"
  if [[ -z "${LOG_DIR+x}" ]]; then
    ensure_session_index_mirror_at_base "$session" "${WORKSPACE}/logs"
  elif [[ -n "$LOG_DIR" ]]; then
    ensure_session_index_mirror_at_base "$session" "$LOG_DIR"
  fi
}

_update_session_meta() {
  local session_dir="$1" session="$2" workspace="$3" created_at="$4" updated_at="$5" reason="${6:-manual}" agents_csv="${7:-}"
  local meta_file="${session_dir}/.meta"
  python3 - "$meta_file" "$session" "$workspace" "$created_at" "$updated_at" "$reason" "$agents_csv" <<'PYEOF'
import json, os, sys

path, session, workspace, created_at, updated_at, reason, agents_csv = sys.argv[1:8]
if os.path.exists(path):
    try:
        with open(path, "r") as f:
            data = json.load(f)
    except json.JSONDecodeError:
        try:
            with open(path, "r") as f:
                data, _ = json.JSONDecoder().raw_decode(f.read())
        except Exception:
            data = {"session": session, "workspace": workspace, "created_at": created_at, "updated_at": updated_at, "overwrite_count": 0, "overwrites": []}
else:
    data = {"session": session, "workspace": workspace, "created_at": created_at, "updated_at": updated_at, "overwrite_count": 0, "overwrites": []}

data["session"] = session
data["workspace"] = workspace
data["created_at"] = data.get("created_at", created_at)
data["updated_at"] = updated_at
overwrites = data.setdefault("overwrites", [])
overwrites.append({"timestamp": updated_at, "reason": reason})
data["overwrite_count"] = len(overwrites)
if agents_csv.strip():
    data["agents"] = [a.strip() for a in agents_csv.split(",") if a.strip()]

with open(path, "w") as f:
    json.dump(data, f, indent=2, ensure_ascii=True)
    f.write("\n")
PYEOF
}

_save_pane_logs_to_dir() {
  local session="$1" base_dir="$2" reason="${3:-manual}"
  local resolved session_dir created_at updated_at
  resolved="$(_session_log_dir "$session" "$base_dir")"
  IFS=$'\t' read -r session_dir created_at updated_at <<< "$resolved"
  local agents_str saved=0
  agents_str="$(tmux show-environment -t "$session" MULTIAGENT_AGENTS 2>/dev/null | sed 's/^[^=]*=//' || true)"
  [[ -z "$agents_str" ]] && agents_str="$ALL_AGENTS_CSV"
  IFS=',' read -ra _save_agents <<< "$agents_str"
  for instance in "${_save_agents[@]}"; do
    local upper pane_id ans_file txt_file
    upper="$(echo "$instance" | tr '[:lower:]-' '[:upper:]_')"
    pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | cut -d= -f2 || true)"
    [[ -z "$pane_id" ]] && continue
    ans_file="${session_dir}/${instance}.ans"
    txt_file="${session_dir}/${instance}.log"
    # Capture to a temp file first so we can compare sizes before overwriting
    local tmp_ans="${ans_file}.tmp.$$"
    tmux capture-pane -p -e -S - -t "$pane_id" 2>/dev/null > "$tmp_ans" || true
    # Protect old capture when a pane reset is detected.
    # Primary trigger: new capture is less than half the old size (>1KB).
    # Secondary trigger: sizes are comparable but content hash differs completely
    # and the old file is non-trivial.  This catches agent restarts that produce
    # similar-length but entirely different output.
    if [[ -f "$ans_file" ]]; then
      local old_size new_size
      old_size="$(wc -c < "$ans_file" 2>/dev/null)" || old_size=0
      new_size="$(wc -c < "$tmp_ans" 2>/dev/null)" || new_size=0
      local _do_protect=0 _protect_reason="size"
      # Primary: significant size shrink
      if [[ "$old_size" -gt 1024 && "$new_size" -gt 0 && $((new_size * 2)) -lt "$old_size" ]]; then
        _do_protect=1
      # Secondary: similar size but completely different content
      elif [[ "$old_size" -gt 1024 && "$new_size" -gt 0 && $((new_size * 2)) -ge "$old_size" ]]; then
        local old_hash new_hash
        old_hash="$(head -c 4096 "$ans_file" | shasum -a 256 | cut -d' ' -f1 2>/dev/null)" || old_hash=""
        new_hash="$(head -c 4096 "$tmp_ans" | shasum -a 256 | cut -d' ' -f1 2>/dev/null)" || new_hash=""
        if [[ -n "$old_hash" && -n "$new_hash" && "$old_hash" != "$new_hash" ]]; then
          # Also check the tail to distinguish append-only growth from reset
          local old_tail new_tail
          old_tail="$(tail -c 1024 "$ans_file" | shasum -a 256 | cut -d' ' -f1 2>/dev/null)" || old_tail=""
          new_tail="$(tail -c 1024 "$tmp_ans" | shasum -a 256 | cut -d' ' -f1 2>/dev/null)" || new_tail=""
          if [[ -n "$old_tail" && -n "$new_tail" && "$old_tail" != "$new_tail" ]]; then
            _do_protect=1
            _protect_reason="hash"
          fi
        fi
      fi
      if [[ "$_do_protect" -eq 1 ]]; then
        local ts protect_ans protect_txt
        ts="$(date +%Y%m%d_%H%M%S)"
        protect_ans="${session_dir}/${instance}.${ts}.protected.ans"
        protect_txt="${session_dir}/${instance}.${ts}.protected.log"
        cp "$ans_file" "$protect_ans" 2>/dev/null || true
        [[ -f "$txt_file" ]] && cp "$txt_file" "$protect_txt" 2>/dev/null || true
        echo "[multiagent] Pane content changed (${old_size}->${new_size} bytes, ${_protect_reason}). Protected: $protect_ans" >&2
      fi
    fi
    mv "$tmp_ans" "$ans_file"
    perl -pe 's/\x1b\[[0-9;?]*[a-zA-Z]//g; s/\x1b\][^\x07]*\x07//g; s/\x1b[(){][AB012]//g; s/\x1b[=>]//g; s/\r//g' < "$ans_file" > "$txt_file" || true
    echo "[multiagent] Updated: $ans_file / $txt_file" >&2
    saved=1
  done
  if [[ "$saved" -eq 1 ]]; then
    _update_session_meta "$session_dir" "$session" "$WORKSPACE" "$created_at" "$updated_at" "$reason" "$agents_str"
    echo "[multiagent] Session log dir: $session_dir" >&2
  fi
}

save_session_logs() {
  local session="$1" reason="${2:-manual}"

  # Logging disabled only when --log-dir '' was explicitly given
  if [[ -z "${LOG_DIR+x}" ]]; then
    local workspace_log_dir="${WORKSPACE}/logs"
  elif [[ -z "$LOG_DIR" ]]; then
    return 0                              # explicitly empty → disabled
  else
    local workspace_log_dir="$LOG_DIR"
  fi

  _save_pane_logs_to_dir "$session" "$workspace_log_dir" "$reason"

  if [[ "${workspace_log_dir}" != "${CENTRAL_LOG_DIR}" ]]; then
    _save_pane_logs_to_dir "$session" "$CENTRAL_LOG_DIR" "$reason"
  fi
}

append_session_system_entry() {
  local session="$1" message="$2" kind="${3:-session-topology}" action="${4:-}" subject="${5:-}" initiator="${6:-}"
  local index_path
  index_path="$(_canonical_session_index_path "$session")"
  ensure_session_index_mirrors "$session"
  python3 - "$index_path" "$session" "$message" "$kind" "$action" "$subject" "$initiator" <<'PYEOF'
import fcntl
import json
import os
import sys
import uuid
from datetime import datetime

path, session, message, kind, action, subject, initiator = sys.argv[1:8]
entry = {
    "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
    "session": session,
    "sender": "system",
    "targets": [],
    "message": message,
    "msg_id": uuid.uuid4().hex[:12],
    "kind": kind,
}
if action:
    entry["topology_action"] = action
if subject:
    entry["agent_instance"] = subject
if initiator:
    entry["initiator"] = initiator
os.makedirs(os.path.dirname(path), exist_ok=True)
with open(path, "a", encoding="utf-8") as f:
    fcntl.flock(f, fcntl.LOCK_EX)
    try:
        f.write(json.dumps(entry, ensure_ascii=False) + "\n")
        f.flush()
    finally:
        fcntl.flock(f, fcntl.LOCK_UN)
PYEOF
}

format_session_topology_message() {
  local action="$1" subject="$2" initiator="$3"
  local actor="${initiator:-user}"
  case "$action" in
    add-agent) printf 'Add Agent: %s -> %s\n' "$actor" "$subject" ;;
    remove-agent) printf 'Remove Agent: %s -> %s\n' "$actor" "$subject" ;;
    *) printf 'Session Topology: %s -> %s (%s)\n' "$actor" "$subject" "$action" ;;
  esac
}

start_agent() {
  local pane_id="$1" agent_name="$2" instance_name="${3:-$2}" launch_cmd
  local index_path log_dir_mode log_dir_value
  index_path="$(_canonical_session_index_path "$SESSION_NAME")"
  if [[ -z "${LOG_DIR+x}" ]]; then
    log_dir_mode="unset"
    log_dir_value=""
  else
    log_dir_mode="set"
    log_dir_value="$LOG_DIR"
  fi
  local base_name="${agent_name%%-[0-9]*}"
  local executable launch_extra launch_flags launch_env
  executable="$(resolve_agent_executable "$base_name")" || {
    executable="$(agent_var AGENT_EXECUTABLE "$base_name")"
    [[ -n "$executable" ]] || executable="$base_name"
  }
  launch_extra="$(agent_var AGENT_LAUNCH_EXTRA "$base_name")"
  launch_flags="$(agent_var AGENT_LAUNCH_FLAGS "$base_name")"
  launch_env="$(agent_var AGENT_LAUNCH_ENV "$base_name")"
  launch_cmd="$(python3 - "$REPO_ROOT" "$SCRIPT_DIR" "$SESSION_NAME" "$WORKSPACE" "$TMUX_SOCKET_NAME" "$index_path" "$instance_name" "$log_dir_mode" "$log_dir_value" "$executable" "$launch_extra" "$launch_flags" "$launch_env" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
script_dir = sys.argv[2]
session_name = sys.argv[3]
workspace = sys.argv[4]
tmux_socket = sys.argv[5]
index_path = sys.argv[6]
instance_name = sys.argv[7]
log_dir_mode = sys.argv[8]
log_dir_value = sys.argv[9]
executable = sys.argv[10]
launch_extra = sys.argv[11]
launch_flags = sys.argv[12]
launch_env = sys.argv[13]
log_dir = None if log_dir_mode == "unset" else log_dir_value
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_launch_core import build_agent_launch_command, build_env_exports

env_exports = build_env_exports(
    script_dir=script_dir,
    session_name=session_name,
    workspace=workspace,
    tmux_socket=tmux_socket,
    index_path=index_path,
    agent_name=instance_name,
    log_dir=log_dir,
)
print(
    build_agent_launch_command(
        env_exports=env_exports,
        executable=executable,
        launch_extra=launch_extra,
        launch_flags=launch_flags,
        launch_env=launch_env,
    )
)
PYEOF
  )"
  tmux select-pane -t "$pane_id" -T "$instance_name"
  tmux send-keys -t "$pane_id" "$launch_cmd" Enter
}

start_user_pane() {
  local pane_id="$1" launch_cmd
  local index_path log_dir_mode log_dir_value
  index_path="$(_canonical_session_index_path "$SESSION_NAME")"
  if [[ -z "${LOG_DIR+x}" ]]; then
    log_dir_mode="unset"
    log_dir_value=""
  else
    log_dir_mode="set"
    log_dir_value="$LOG_DIR"
  fi
  launch_cmd="$(python3 - "$REPO_ROOT" "$SCRIPT_DIR" "$SESSION_NAME" "$WORKSPACE" "$TMUX_SOCKET_NAME" "$index_path" "$log_dir_mode" "$log_dir_value" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
script_dir = sys.argv[2]
session_name = sys.argv[3]
workspace = sys.argv[4]
tmux_socket = sys.argv[5]
index_path = sys.argv[6]
log_dir_mode = sys.argv[7]
log_dir_value = sys.argv[8]
log_dir = None if log_dir_mode == "unset" else log_dir_value
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_launch_core import build_env_exports, build_user_launch_command

env_exports = build_env_exports(
    script_dir=script_dir,
    session_name=session_name,
    workspace=workspace,
    tmux_socket=tmux_socket,
    index_path=index_path,
    log_dir=log_dir,
)
print(build_user_launch_command(env_exports=env_exports, script_dir=script_dir))
PYEOF
  )"
  tmux select-pane -t "$pane_id" -T "terminal"
  tmux send-keys -t "$pane_id" C-c
  tmux send-keys -t "$pane_id" "$launch_cmd" Enter
}

if [[ "$MODE" == "add-agent" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  [[ -n "$AGENTS_ARG" ]] || { echo "--agent is required for add-agent" >&2; exit 1; }
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "=$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi

  base_agent="${AGENTS_ARG%%-[0-9]*}"
  if ! agent_in_registry "$base_agent"; then
    echo "Unknown agent: $AGENTS_ARG" >&2
    exit 1
  fi

  load_session_runtime_context "$SESSION_NAME"
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_INDEX_PATH "$(_canonical_session_index_path "$SESSION_NAME")"
  ensure_session_index_mirrors "$SESSION_NAME"

  acquire_session_topology_lock "$SESSION_NAME" || exit 1
  trap 'release_session_topology_lock' EXIT
  reconcile_session_agent_registry "$SESSION_NAME" >/dev/null

  renumber_existing_exact_instance "$SESSION_NAME" "$base_agent"
  instance_name="$(next_instance_name "$SESSION_NAME" "$base_agent")"
  upper_instance="$(printf '%s' "$instance_name" | tr '[:lower:]-' '[:upper:]_')"
  existing_pane="$(tmux show-environment -t "$SESSION_NAME" "MULTIAGENT_PANE_${upper_instance}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
  if [[ -n "$existing_pane" ]]; then
    echo "Agent instance already exists: $instance_name (bug: please report)" >&2
    exit 1
  fi

  required_cmd="$(resolve_agent_executable "$base_agent")" || {
    required_cmd="$(agent_var AGENT_EXECUTABLE "$base_agent")"
    [[ -n "$required_cmd" ]] || required_cmd="$base_agent"
    echo "Required command not found for $base_agent: $required_cmd" >&2
    exit 1
  }

  # Note: ensure_*_agent_send_rules are defined later in the startup flow
  # and not available here. Rules are already configured at session creation
  # time, so we skip them for add-agent.

  if session_uses_per_window_layout "$SESSION_NAME"; then
    new_pane="$(create_agent_window "$SESSION_NAME" "$instance_name")"
    [[ -n "$new_pane" ]] || { echo "Failed to create agent window" >&2; exit 1; }
  else
    target_pane="$(primary_agent_pane_id "$SESSION_NAME")"
    [[ -n "$target_pane" ]] || { echo "No agent pane found in session: $SESSION_NAME" >&2; exit 1; }
    new_pane="$(split_agent_pane "$target_pane" "$WORKSPACE")"
    [[ -n "$new_pane" ]] || { echo "Failed to create pane" >&2; exit 1; }
    configure_agent_pane_defaults "$new_pane"
    user_panes_csv="$(session_user_pane_value "$SESSION_NAME")"
    retile_session_preserving_user_panes "$SESSION_NAME" "$user_panes_csv"
  fi

  current_agents="$(session_agents_value "$SESSION_NAME")"
  updated_agents="$(python3 - "$REPO_ROOT" "$current_agents" "$instance_name" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
agents_csv = sys.argv[2]
instance_name = sys.argv[3]
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_agent_core import agents_to_csv, append_instance, parse_agents_csv

print(agents_to_csv(append_instance(parse_agents_csv(agents_csv), instance_name)))
PYEOF
  )"
  tmux set-environment -t "$SESSION_NAME" "MULTIAGENT_PANE_${upper_instance}" "$new_pane"
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_AGENTS "$updated_agents"
  write_session_state_file "$SESSION_NAME"

  start_agent "$new_pane" "$base_agent" "$instance_name"
  initiator_name="${MULTIAGENT_AGENT_NAME:-user}"
  append_session_system_entry "$SESSION_NAME" "$(format_session_topology_message "add-agent" "$instance_name" "$initiator_name")" "session-topology" "add-agent" "$instance_name" "$initiator_name"

  echo "Added agent $instance_name to session: $SESSION_NAME"
  release_session_topology_lock
  trap - EXIT
  exit 0
fi

if [[ "$MODE" == "remove-agent" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  [[ -n "$AGENTS_ARG" ]] || { echo "--agent is required for remove-agent" >&2; exit 1; }
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "=$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi

  instance_name="$(printf '%s' "$AGENTS_ARG" | tr '[:upper:]' '[:lower:]')"
  load_session_runtime_context "$SESSION_NAME"
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_INDEX_PATH "$(_canonical_session_index_path "$SESSION_NAME")"
  ensure_session_index_mirrors "$SESSION_NAME"

  acquire_session_topology_lock "$SESSION_NAME" || exit 1
  trap 'release_session_topology_lock' EXIT
  reconcile_session_agent_registry "$SESSION_NAME" >/dev/null

  current_agents="$(session_agents_value "$SESSION_NAME")"
  remove_plan="$(python3 - "$REPO_ROOT" "$current_agents" "$instance_name" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
agents_csv = sys.argv[2]
instance_name = sys.argv[3]
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_agent_core import agents_to_csv, parse_agents_csv, remove_instance, resolve_canonical_instance

agents = parse_agents_csv(agents_csv)
canonical = resolve_canonical_instance(agents, instance_name)
if not canonical:
    raise SystemExit(2)
remaining_agents = remove_instance(agents, canonical)
print(canonical)
print(len(remaining_agents))
print(agents_to_csv(remaining_agents))
PYEOF
  )"
  remove_plan_status=$?
  if [[ "$remove_plan_status" -eq 2 ]]; then
    echo "Agent instance not in this session: $AGENTS_ARG (current: ${current_agents:-none})" >&2
    exit 1
  fi
  [[ "$remove_plan_status" -eq 0 ]] || exit "$remove_plan_status"
  canonical="$(printf '%s\n' "$remove_plan" | sed -n '1p')"
  remaining="$(printf '%s\n' "$remove_plan" | sed -n '2p')"
  updated_agents="$(printf '%s\n' "$remove_plan" | sed -n '3p')"
  if [[ "$remaining" -lt 1 ]]; then
    echo "Cannot remove the last agent pane" >&2
    exit 1
  fi

  upper_instance="$(printf '%s' "$canonical" | tr '[:lower:]-' '[:upper:]_')"
  pane_id="$(tmux show-environment -t "$SESSION_NAME" "MULTIAGENT_PANE_${upper_instance}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
  if [[ -z "$pane_id" ]]; then
    echo "No tmux pane recorded for instance: $canonical" >&2
    exit 1
  fi
  user_panes_csv="$(session_user_pane_value "$SESSION_NAME")"
  if [[ -n "$user_panes_csv" ]]; then
    IFS=',' read -ra _up_ids <<< "$user_panes_csv"
    for _up in "${_up_ids[@]}"; do
      [[ -n "$_up" && "$_up" == "$pane_id" ]] && { echo "Refusing to remove a user/terminal pane" >&2; exit 1; }
    done
  fi

  if [[ "${TMUX_PANE:-}" == "$pane_id" ]] && [[ "${MULTIAGENT_REMOVE_HELPER:-0}" != "1" ]]; then
    if command -v nohup >/dev/null 2>&1; then
      nohup env \
        MULTIAGENT_REMOVE_HELPER=1 \
        MULTIAGENT_SKIP_DEPS_CHECK=1 \
        MULTIAGENT_SESSION="$SESSION_NAME" \
        MULTIAGENT_TMUX_SOCKET="$TMUX_SOCKET_NAME" \
        "$SCRIPT_DIR/multiagent" remove-agent --session "$SESSION_NAME" --agent "$canonical" \
        >/dev/null 2>&1 </dev/null &
    else
      env \
        MULTIAGENT_REMOVE_HELPER=1 \
        MULTIAGENT_SKIP_DEPS_CHECK=1 \
        MULTIAGENT_SESSION="$SESSION_NAME" \
        MULTIAGENT_TMUX_SOCKET="$TMUX_SOCKET_NAME" \
        "$SCRIPT_DIR/multiagent" remove-agent --session "$SESSION_NAME" --agent "$canonical" \
        >/dev/null 2>&1 </dev/null &
    fi
    disown >/dev/null 2>&1 || true
    echo "Scheduled removal of agent $canonical from session: $SESSION_NAME"
    exit 0
  fi

  if session_uses_per_window_layout "$SESSION_NAME"; then
    window_target="$(window_target_for_pane "$pane_id")"
    [[ -n "$window_target" ]] || { echo "No tmux window recorded for instance: $canonical" >&2; exit 1; }
    if ! kill_window_target "$window_target"; then
      echo "tmux kill-window failed for $window_target" >&2
      exit 1
    fi
  else
    if ! kill_pane_target "$pane_id"; then
      echo "tmux kill-pane failed for $pane_id" >&2
      exit 1
    fi
  fi

  tmux set-environment -t "$SESSION_NAME" -u "MULTIAGENT_PANE_${upper_instance}" 2>/dev/null || true
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_AGENTS "$updated_agents"

  if ! session_uses_per_window_layout "$SESSION_NAME"; then
    user_panes_csv="$(session_user_pane_value "$SESSION_NAME")"
    retile_session_preserving_user_panes "$SESSION_NAME" "$user_panes_csv"
  fi

  write_session_state_file "$SESSION_NAME"
  initiator_name="${MULTIAGENT_AGENT_NAME:-user}"
  append_session_system_entry "$SESSION_NAME" "$(format_session_topology_message "remove-agent" "$canonical" "$initiator_name")" "session-topology" "remove-agent" "$canonical" "$initiator_name"
  echo "Removed agent $canonical from session: $SESSION_NAME"
  release_session_topology_lock
  trap - EXIT
  exit 0
fi


if tmux has-session -t "=$SESSION_NAME" 2>/dev/null; then
  echo "Session already exists: $SESSION_NAME" >&2
  exit 1
fi

# --- Create session with one window per agent ---
NUM_AGENTS=${#SELECTED_AGENTS[@]}

if [[ "$FRESH" -eq 1 ]]; then
  for _fresh_base in "${WORKSPACE}/logs" "$CENTRAL_LOG_DIR"; do
    [[ -d "$_fresh_base" ]] || continue
    while IFS= read -r _fresh_dir; do
      [[ -n "$_fresh_dir" ]] || continue
      rm -rf "$_fresh_dir"
      echo "[multiagent] Removed: $_fresh_dir" >&2
    done < <(find "$_fresh_base" -maxdepth 1 -type d -name "${SESSION_NAME}_*")
  done
fi

ensure_session_agent_doc

tmux new-session -d -x "$AGENT_WINDOW_WIDTH" -y "$AGENT_WINDOW_HEIGHT" -s "$SESSION_NAME" -c "$WORKSPACE"
configure_window_size "$SESSION_NAME":0
tmux rename-window -t "$SESSION_NAME":0 terminal >/dev/null 2>&1 || true

USER_PANE_ID=""
USER_PANE_IDS=()
if [[ "$USER_PANE" != "none" ]]; then
  USER_PANE_ID="$(tmux display-message -p -t "$SESSION_NAME":0.0 '#{pane_id}')"
  USER_PANE_IDS=("$USER_PANE_ID")
  if [[ "$USER_PANE_TOP_COUNT" -gt 0 ]]; then
    create_user_pane_band "$USER_PANE_ID" top "$USER_PANE_TOP_COUNT"
  fi
  if [[ "$USER_PANE_BOTTOM_COUNT" -gt 0 ]]; then
    create_user_pane_band "$USER_PANE_ID" bottom "$USER_PANE_BOTTOM_COUNT"
  fi
fi

for pane_id in "${USER_PANE_IDS[@]}"; do
  tmux select-pane -t "$pane_id" -T "terminal"
done

tmux set-option -t "$SESSION_NAME" -g remain-on-exit on
tmux set-option -t "$SESSION_NAME" -g mouse on
tmux set-option -t "$SESSION_NAME" -g pane-border-style fg='#38393D'
tmux set-option -t "$SESSION_NAME" -g pane-active-border-style fg='#38393D'
tmux set-option -t "$SESSION_NAME" -g status-style bg='#38393D',fg='#ACB4BE'
tmux set-option -t "$SESSION_NAME" -g history-limit 50000
tmux set-option -t "$SESSION_NAME" -g @scroll-speed-num-lines-per-scroll 1 2>/dev/null || true

PANES=()
for (( i=0; i<NUM_AGENTS; i++ )); do
  pane_id="$(create_agent_window "$SESSION_NAME" "${INSTANCE_NAMES[$i]}")"
  [[ -n "$pane_id" ]] || { echo "Failed to create agent window for ${INSTANCE_NAMES[$i]}" >&2; exit 1; }
  PANES+=("$pane_id")
done

tmux set-environment -t "$SESSION_NAME" MULTIAGENT_SESSION "$SESSION_NAME"
tmux set-environment -t "$SESSION_NAME" MULTIAGENT_WORKSPACE "$WORKSPACE"
tmux set-environment -t "$SESSION_NAME" MULTIAGENT_BIN_DIR "$SCRIPT_DIR"
tmux set-environment -t "$SESSION_NAME" MULTIAGENT_TMUX_SOCKET "$TMUX_SOCKET_NAME"
tmux set-environment -t "$SESSION_NAME" MULTIAGENT_LAYOUT per-window
if [[ -n "$USER_PANE_ID" ]]; then
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_PANE_USER "$USER_PANE_ID"
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_PANES_USER "$(IFS=,; echo "${USER_PANE_IDS[*]-}")"
else
  tmux set-environment -t "$SESSION_NAME" -u MULTIAGENT_PANE_USER 2>/dev/null || true
  tmux set-environment -t "$SESSION_NAME" -u MULTIAGENT_PANES_USER 2>/dev/null || true
fi
if [[ -z "${LOG_DIR+x}" ]]; then
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_LOG_DIR "${WORKSPACE}/logs"
elif [[ -z "$LOG_DIR" ]]; then
  tmux set-environment -t "$SESSION_NAME" -u MULTIAGENT_LOG_DIR 2>/dev/null || true
else
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_LOG_DIR "$LOG_DIR"
fi
tmux set-environment -t "$SESSION_NAME" MULTIAGENT_INDEX_PATH "$(_canonical_session_index_path "$SESSION_NAME")"
tmux set-environment -t "$SESSION_NAME" -u CLAUDECODE 2>/dev/null || true
ensure_session_index_mirrors "$SESSION_NAME"

# Set per-instance env vars: MULTIAGENT_PANE_CLAUDE_1, MULTIAGENT_PANE_CLAUDE_2, etc.
for (( i=0; i<NUM_AGENTS; i++ )); do
  instance="${INSTANCE_NAMES[$i]}"
  pane="${PANES[$i]}"
  upper=$(echo "$instance" | tr '[:lower:]-' '[:upper:]_')
  tmux set-environment -t "$SESSION_NAME" "MULTIAGENT_PANE_${upper}" "$pane"
done
# Store the full ordered instance list
tmux set-environment -t "$SESSION_NAME" MULTIAGENT_AGENTS "$(IFS=,; echo "${INSTANCE_NAMES[*]}")"

# Write state file so agent-send can resolve pane IDs even in sandboxed
# environments (e.g. Codex CLI) that do not inherit tmux env vars.
write_session_state_file "$SESSION_NAME"

ensure_codex_agent_send_rules() {
  local rules_file="${CODEX_HOME:-$HOME/.codex}/rules/default.rules"
  mkdir -p "$(dirname "$rules_file")"
  touch "$rules_file"
  local tool_rule
  printf -v tool_rule 'prefix_rule(pattern=["%s/agent-send", "--session", "%s"], decision="allow")' "$SCRIPT_DIR" "$SESSION_NAME"
  for rule in 'prefix_rule(pattern=["agent-send"], decision="allow")' \
              'prefix_rule(pattern=["./bin/agent-send"], decision="allow")' \
              "$tool_rule"; do
    grep -Fqx "$rule" "$rules_file" || printf '%s\n' "$rule" >> "$rules_file"
  done
}

ensure_gemini_agent_send_rules() {
  local settings_file="$WORKSPACE/.gemini/settings.json"
  mkdir -p "$(dirname "$settings_file")"
  [[ -f "$settings_file" ]] || echo '{}' > "$settings_file"
  python3 - "$settings_file" "$SCRIPT_DIR" <<'PYEOF'
import json, sys
settings_file, script_dir = sys.argv[1], sys.argv[2]
with open(settings_file, 'r') as f: data = json.load(f)
data.setdefault('tools', {}).setdefault('allowed', [])
for r in [f'run_shell_command({script_dir}/agent-send)', 'run_shell_command(agent-send)']:
    if r not in data['tools']['allowed']:
        data['tools']['allowed'].append(r)
with open(settings_file, 'w') as f: json.dump(data, f, indent=2)
PYEOF
}

ensure_qwen_agent_send_rules() {
  local settings_file="$WORKSPACE/.qwen/settings.json"
  mkdir -p "$(dirname "$settings_file")"
  [[ -f "$settings_file" ]] || echo '{}' > "$settings_file"
  python3 - "$settings_file" "$SCRIPT_DIR" <<'PYEOF'
import json, sys
settings_file, script_dir = sys.argv[1], sys.argv[2]
with open(settings_file, 'r') as f: data = json.load(f)
data.setdefault('tools', {}).setdefault('allowed', [])
for r in [f'run_shell_command({script_dir}/agent-send)', 'run_shell_command(agent-send)']:
    if r not in data['tools']['allowed']:
        data['tools']['allowed'].append(r)
with open(settings_file, 'w') as f: json.dump(data, f, indent=2)
PYEOF
}

ensure_claude_agent_send_rules() {
  local settings_file="$WORKSPACE/.claude/settings.local.json"
  local rules=(
    "Bash($SCRIPT_DIR/*)"
    "Bash(agent-send *)"
    "Bash(tmux *)"
    "Bash(printf \\\\033c*)"
    "Bash(clear*)"
  )
  mkdir -p "$(dirname "$settings_file")"
  [[ -f "$settings_file" ]] || echo '{"permissions": {"allow": []}}' > "$settings_file"
  local rules_json
  rules_json="$(printf '"%s", ' "${rules[@]}" | sed 's/, $//')"
  python3 - "$settings_file" <<PYEOF
import json, sys
path = sys.argv[1]
with open(path, 'r') as f: data = json.load(f)
data.setdefault('permissions', {}).setdefault('allow', [])
for r in [$rules_json]:
    if r not in data['permissions']['allow']:
        data['permissions']['allow'].append(r)
with open(path, 'w') as f: json.dump(data, f, indent=2)
PYEOF
}

ensure_copilot_agent_send_rules() {
  local config_file="${HOME}/.copilot/config.json"
  mkdir -p "$(dirname "$config_file")"
  [[ -f "$config_file" ]] || echo '{"trusted_folders": []}' > "$config_file"
  python3 - "$config_file" "$WORKSPACE" <<'PYEOF'
import json, sys
path, folder = sys.argv[1], sys.argv[2]
with open(path, 'r') as f: data = json.load(f)
data.setdefault('trusted_folders', [])
if folder not in data['trusted_folders']:
    data['trusted_folders'].append(folder)
with open(path, 'w') as f: json.dump(data, f, indent=2)
PYEOF

  local instructions_dir="$WORKSPACE/.github"
  local instructions_file="$instructions_dir/copilot-instructions.md"
  mkdir -p "$instructions_dir"
  cat > "$instructions_file" << INSTREOF
# Multiagent 環境

あなたは **tmux セッション** 上で Claude・Codex・Gemini・Copilot・Cursor・Grok・OpenCode・Qwen・Aider などと並行して動作しています。
セッション名: \`${SESSION_NAME}\`（環境変数 \`MULTIAGENT_SESSION\` でも確認可能）

## 他のエージェントにメッセージを送る

\`agent-send\` コマンドを使います。このコマンドはすでに PATH に追加済みです。本文は stdin で渡します。

\`\`\`bash
printf '%s' 'メッセージ' | agent-send <claude|codex|gemini|kimi|copilot|cursor|grok|opencode|qwen|aider|others|claude,codex>
\`\`\`

本文は stdin で渡します。複数行でも agent-send の基本形に寄せてください。

もし \`agent-send\` が見つからない場合は絶対パスで実行できます：

\`\`\`bash
printf '%s' 'メッセージ' | "${SCRIPT_DIR}/agent-send" <target>
\`\`\`
INSTREOF
}

for agent in "${SELECTED_AGENTS[@]}"; do
  case "$agent" in
    codex)   ensure_codex_agent_send_rules ;;
    gemini)  ensure_gemini_agent_send_rules ;;
    qwen)    ensure_qwen_agent_send_rules ;;
    claude)  ensure_claude_agent_send_rules ;;
    copilot) ensure_copilot_agent_send_rules ;;
  esac
done

# Start agents with highest startup_priority first (with a delay between priority groups)
_priority_idx=-1
_max_priority=0
for (( i=0; i<NUM_AGENTS; i++ )); do
  _p="$(agent_var AGENT_STARTUP_PRIORITY "${SELECTED_AGENTS[$i]}")"
  [[ -n "$_p" && "$_p" -gt "$_max_priority" ]] && _max_priority="$_p" && _priority_idx=$i
done

if [[ $_priority_idx -ge 0 && $_max_priority -gt 0 ]]; then
  start_agent "${PANES[$_priority_idx]}" "${SELECTED_AGENTS[$_priority_idx]}" "${INSTANCE_NAMES[$_priority_idx]}"
  sleep 3
  for (( i=0; i<NUM_AGENTS; i++ )); do
    [[ $i -eq $_priority_idx ]] && continue
    start_agent "${PANES[$i]}" "${SELECTED_AGENTS[$i]}" "${INSTANCE_NAMES[$i]}"
  done
else
  for (( i=0; i<NUM_AGENTS; i++ )); do
    start_agent "${PANES[$i]}" "${SELECTED_AGENTS[$i]}" "${INSTANCE_NAMES[$i]}"
  done
fi

if [[ ${#USER_PANE_IDS[@]} -gt 0 ]]; then
  for pane_id in "${USER_PANE_IDS[@]}"; do
    start_user_pane "$pane_id"
  done
  open_chat_in_user_pane "$USER_PANE_ID"
fi


if [[ -z "${LOG_DIR+x}" ]]; then
  _hook_log_dir="${WORKSPACE}/logs"
elif [[ -z "$LOG_DIR" ]]; then
  _hook_log_dir=""
else
  _hook_log_dir="$LOG_DIR"
fi

if [[ -n "$_hook_log_dir" ]]; then
  emit_session_save_hook "$SESSION_NAME" "$_hook_log_dir" "$WORKSPACE" "$TMUX_SOCKET_NAME"
fi

if [[ -n "$USER_PANE_ID" ]]; then
  tmux select-pane -t "$USER_PANE_ID"
else
  tmux select-pane -t "${PANES[0]}"
fi

if [[ "$AUTO" -eq 1 ]]; then
  "$SCRIPT_DIR/multiagent-auto-mode" on --session "$SESSION_NAME" >&2 || true
fi

[[ "$DETACH" -eq 1 ]] && { echo "Started tmux session: $SESSION_NAME"; exit 0; }
exec_tmux attach-session -t "$SESSION_NAME"
