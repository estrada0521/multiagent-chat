#!/usr/bin/env bash

set -euo pipefail

# Resolve symlinks so SCRIPT_DIR always points to the actual bin/ directory
# even when invoked via a symlink (e.g. ~/.local/bin/multiagent -> .../multiagent/bin/multiagent).
# Do not use python3 here — it may not exist yet (ensure-multiagent-deps installs it).
multiagent_resolve_script_path() {
  local p="${BASH_SOURCE[0]:-$0}"
  while [[ -L "$p" ]]; do
    local d targ
    d="$(cd "$(dirname "$p")" && pwd)"
    targ="$(readlink "$p")"
    if [[ "$targ" == /* ]]; then
      p="$targ"
    else
      p="$d/$targ"
    fi
  done
  printf '%s\n' "$p"
}
_REAL_SCRIPT="$(multiagent_resolve_script_path)"
SCRIPT_DIR="$(cd "$(dirname "$_REAL_SCRIPT")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Homebrew の典型パス（ensure-multiagent-deps 直後など PATH に無い場合）
for _hp in /opt/homebrew/bin /usr/local/bin; do
  case ":${PATH:-}:" in *:"${_hp}":*) ;; *)
    [[ -d "$_hp" ]] && PATH="${_hp}:$PATH"
    ;;
  esac
done
export PATH

if [[ "${MULTIAGENT_SKIP_DEPS_CHECK:-}" != "1" ]]; then
  if ! command -v python3 >/dev/null 2>&1 || ! command -v tmux >/dev/null 2>&1; then
    if [[ -x "$SCRIPT_DIR/ensure-multiagent-deps" ]]; then
      "$SCRIPT_DIR/ensure-multiagent-deps"
    elif [[ -f "$SCRIPT_DIR/ensure-multiagent-deps" ]]; then
      bash "$SCRIPT_DIR/ensure-multiagent-deps"
    else
      echo "multiagent: python3 と tmux が必要です。${REPO_ROOT}/bin/ensure-multiagent-deps を実行してください。" >&2
      exit 1
    fi
  fi
fi

eval "$(python3 "$REPO_ROOT/lib/agent_registry_shell.py")"
# Central log dir is always <multiagent-repo>/logs (sibling of bin/)
APP_NAME="$(basename "$0")"
CENTRAL_LOG_DIR="${REPO_ROOT}/logs"
SESSION_NAME="${MULTIAGENT_SESSION_NAME:-}"
SESSION_NAME_EXPLICIT=0
WORKSPACE="$PWD"
DETACH=0
FRESH=0
AUTO=1
AGENTS_ARG=""
INSTALL=0
USER_PANE="bottom:1"
USER_PANE_TOP_COUNT=0
USER_PANE_BOTTOM_COUNT=0
MODE="up"
LIST_VERBOSE=0
ALL_SESSIONS=0
LATEST_SESSION=0
RENAME_TO=""
CONTEXT_JSON=0
# LOG_DIR intentionally left unset; set below based on --log-dir flag
AGENT_WINDOW_WIDTH=66
AGENT_WINDOW_HEIGHT=60

default_tmux_socket_name() {
  python3 - "$REPO_ROOT" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.session_path_core import default_tmux_socket_name

print(default_tmux_socket_name(repo_root))
PYEOF
}

TMUX_SOCKET_NAME="${MULTIAGENT_TMUX_SOCKET:-$(default_tmux_socket_name)}"
SESSION_TOPOLOGY_LOCK_DIR=""

# Path for pane env snapshot used by agent-send. Absolute socket paths may contain '/',
# so they are hashed instead of embedded in the filename.
multiagent_panes_state_path() {
  local sock="${1:-$TMUX_SOCKET_NAME}"
  local session_name="${2:-${SESSION_NAME:-${MULTIAGENT_SESSION:-default}}}"
  python3 - "$REPO_ROOT" "$sock" "$session_name" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
sock = sys.argv[2]
session_name = sys.argv[3]
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.session_path_core import multiagent_panes_state_path

print(multiagent_panes_state_path(sock, session_name))
PYEOF
}

session_topology_lock_dir() {
  local sock="${1:-$TMUX_SOCKET_NAME}"
  local session_name="${2:-${SESSION_NAME:-${MULTIAGENT_SESSION:-default}}}"
  python3 - "$REPO_ROOT" "$sock" "$session_name" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
sock = sys.argv[2]
session_name = sys.argv[3]
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.session_path_core import session_topology_lock_path

print(session_topology_lock_path(sock, session_name))
PYEOF
}

release_session_topology_lock() {
  if [[ -n "$SESSION_TOPOLOGY_LOCK_DIR" ]]; then
    python3 - "$REPO_ROOT" "$SESSION_TOPOLOGY_LOCK_DIR" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
lock_dir = Path(sys.argv[2])
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_state_core import release_topology_lock

release_topology_lock(lock_dir)
PYEOF
  fi
  SESSION_TOPOLOGY_LOCK_DIR=""
}

acquire_session_topology_lock() {
  local session="$1" lock_dir
  lock_dir="$(session_topology_lock_dir "$TMUX_SOCKET_NAME" "$session")"
  if python3 - "$REPO_ROOT" "$lock_dir" "$$" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
lock_dir = Path(sys.argv[2])
holder_pid = int(sys.argv[3])
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_state_core import acquire_topology_lock

raise SystemExit(0 if acquire_topology_lock(lock_dir, holder_pid) else 1)
PYEOF
  then
    SESSION_TOPOLOGY_LOCK_DIR="$lock_dir"
    return 0
  fi
  echo "Timed out waiting for topology lock: $session" >&2
  return 1
}

stop_session_chat_server() {
  local session_name="$1"
  python3 - "$REPO_ROOT" "$session_name" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
session_name = (sys.argv[2] or "").strip()
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_session_core import stop_session_chat_server

ok, detail = stop_session_chat_server(repo_root, session_name)
if not ok:
    if detail:
        print(detail, file=sys.stderr)
    raise SystemExit(1)
PYEOF
}

agent_in_registry() {
  local candidate="$1" agent
  for agent in "${ALL_AGENTS[@]}"; do
    [[ "$candidate" == "$agent" ]] && return 0
  done
  return 1
}

agent_var() {
  local prefix="$1"
  local agent="$2"
  local var_name="${prefix}_${agent}"
  eval "printf '%s' \"\${${var_name}:-}\""
}

resolve_agent_executable() {
  local agent="$1"
  python3 - "$REPO_ROOT" "$agent" <<'PYEOF'
import os
import shutil
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
agent_name = sys.argv[2]

sys.path.insert(0, str(repo_root / "lib"))
from agent_index.ensure_agent_clis import resolve_agent_executable

resolved = resolve_agent_executable(repo_root, agent_name)
if resolved:
    print(resolved)
    raise SystemExit(0)

base = agent_name.split("-", 1)[0]
print(base)
raise SystemExit(1)
PYEOF
}

tmux() {
  case "$TMUX_SOCKET_NAME" in
    /*) command tmux -S "$TMUX_SOCKET_NAME" "$@" ;;
    *) command tmux -L "$TMUX_SOCKET_NAME" "$@" ;;
  esac
}

exec_tmux() {
  case "$TMUX_SOCKET_NAME" in
    /*) exec command tmux -S "$TMUX_SOCKET_NAME" "$@" ;;
    *) exec command tmux -L "$TMUX_SOCKET_NAME" "$@" ;;
  esac
}

default_session_name() {
  basename "$WORKSPACE"
}

realpath_or_echo() {
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1" 2>/dev/null || printf '%s\n' "$1"
}

ensure_session_agent_doc() {
  local src="$SCRIPT_DIR/../docs/AGENT.md"
  local dest_dir="$WORKSPACE/docs"
  local dest="$dest_dir/AGENT.md"
  [[ -f "$src" ]] || return 0
  mkdir -p "$dest_dir"
  cmp -s "$src" "$dest" 2>/dev/null && return 0
  cp "$src" "$dest"
}

session_pane_count() {
  local session="$1"
  tmux list-panes -s -t "$session" 2>/dev/null | wc -l | tr -d ' '
}

session_window_count() {
  local session="$1"
  tmux list-windows -t "$session" 2>/dev/null | wc -l | tr -d ' '
}

session_created_value() {
  local session="$1"
  local epoch
  epoch="$(tmux display-message -p -t "$session" '#{session_created}' 2>/dev/null || true)"
  [[ -n "$epoch" ]] && date -r "$epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || true
}

session_attached_value() {
  local session="$1"
  tmux display-message -p -t "$session" '#{session_attached}' 2>/dev/null || true
}

load_session_runtime_context() {
  local session="$1" env_output parsed key value
  env_output="$(tmux show-environment -t "$session" 2>/dev/null || true)"
  parsed="$(python3 - "$REPO_ROOT" "$env_output" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
env_output = sys.argv[2]
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_session_core import session_context_from_env_output

context = session_context_from_env_output(env_output)
print(f"WORKSPACE={context.get('workspace', '')}")
print(f"BIN_DIR={context.get('bin_dir', '')}")
print(f"TMUX_SOCKET={context.get('tmux_socket', '')}")
print(f"LOG_DIR={context.get('log_dir', '')}")
PYEOF
  )"

  session_workspace=""
  session_bin_dir=""
  session_socket=""
  session_log_dir=""
  while IFS='=' read -r key value; do
    case "$key" in
      WORKSPACE) session_workspace="$value" ;;
      BIN_DIR) session_bin_dir="$value" ;;
      TMUX_SOCKET) session_socket="$value" ;;
      LOG_DIR) session_log_dir="$value" ;;
    esac
  done <<< "$parsed"

  [[ -n "$session_workspace" ]] && WORKSPACE="$session_workspace"
  [[ -n "$session_bin_dir" ]] && SCRIPT_DIR="$session_bin_dir"
  [[ -n "$session_socket" ]] && TMUX_SOCKET_NAME="$session_socket"
  if [[ -n "$session_log_dir" ]]; then
    LOG_DIR="$session_log_dir"
  else
    unset LOG_DIR
  fi
}

session_user_pane_value() {
  local session="$1"
  local panes
  panes="$(tmux show-environment -t "$session" MULTIAGENT_PANES_USER 2>/dev/null | sed 's/^[^=]*=//' || true)"
  if [[ -n "$panes" ]]; then
    printf '%s\n' "$panes"
  else
    tmux show-environment -t "$session" MULTIAGENT_PANE_USER 2>/dev/null | sed 's/^[^=]*=//' || true
  fi
}

primary_user_pane_id() {
  local session="$1" panes
  panes="$(session_user_pane_value "$session")"
  panes="${panes%%,*}"
  [[ -n "$panes" ]] && printf '%s\n' "$panes"
}

primary_agent_pane_id() {
  local session="$1"
  if session_uses_per_window_layout "$session"; then
    local agents_str instance upper pane_id
    agents_str="$(session_agents_value "$session")"
    [[ "$agents_str" == "-" ]] && return 0
    IFS=',' read -ra _agent_instances <<< "$agents_str"
    for instance in "${_agent_instances[@]}"; do
      [[ -n "$instance" ]] || continue
      upper="$(printf '%s' "$instance" | tr '[:lower:]-' '[:upper:]_')"
      pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
      [[ -n "$pane_id" ]] && { printf '%s\n' "$pane_id"; return 0; }
    done
    return 0
  fi
  local user_pattern
  user_pattern="$(session_user_pane_value "$session")"
  tmux list-panes -t "$session":0 -F '#{pane_id}' 2>/dev/null | awk -v users="$user_pattern" '
    BEGIN {
      n=split(users, ids, /,/);
      for (i=1; i<=n; i++) if (ids[i] != "") excluded[ids[i]]=1;
    }
    !excluded[$1] { print $1; exit }
  '
}

parse_user_pane_spec() {
  local spec="$1" parsed
  if ! parsed="$(python3 - "$REPO_ROOT" "$spec" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
spec = sys.argv[2]
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_topology_core import parse_user_pane_spec

try:
    top, bottom = parse_user_pane_spec(spec)
except ValueError:
    raise SystemExit(1)

print(f"{top}\t{bottom}")
PYEOF
  )"; then
    return 1
  fi
  IFS=$'\t' read -r USER_PANE_TOP_COUNT USER_PANE_BOTTOM_COUNT <<< "$parsed"
  [[ -n "$USER_PANE_TOP_COUNT" && -n "$USER_PANE_BOTTOM_COUNT" ]]
}

retile_session_preserving_user_panes() {
  local session="$1" user_panes_csv="${2:-}"
  python3 - "$REPO_ROOT" "$session" "$user_panes_csv" "$TMUX_SOCKET_NAME" <<'PYEOF'
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
session = sys.argv[2]
user_panes_csv = sys.argv[3]
tmux_socket = sys.argv[4]
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.multiagent_tmux_core import retile_session_preserving_user_panes

retile_session_preserving_user_panes(
    session=session,
    user_panes_csv=user_panes_csv,
    tmux_socket=tmux_socket,
)
PYEOF
}

create_user_pane_band() {
  local target="$1" side="$2" count="$3" pane_height="${4:-1}"
  local band_id pane_id remaining
  if [[ "$side" == "top" ]]; then
    band_id="$(tmux split-window -v -b -l "$pane_height" -P -F '#{pane_id}' -t "$target" -c "$WORKSPACE")"
  else
    band_id="$(tmux split-window -v -l "$pane_height" -P -F '#{pane_id}' -t "$target" -c "$WORKSPACE")"
  fi
  USER_PANE_IDS+=("$band_id")
  for (( i=1; i<count; i++ )); do
    remaining=$((count - i + 1))
    pane_id="$(tmux split-window -h -b -p $((100 / remaining)) -P -F '#{pane_id}' -t "$band_id" -c "$WORKSPACE")"
    USER_PANE_IDS+=("$pane_id")
  done
}

session_layout_value() {
  local session="$1" layout
  layout="$(tmux show-environment -t "$session" MULTIAGENT_LAYOUT 2>/dev/null | sed 's/^[^=]*=//' || true)"
  [[ -n "$layout" ]] && printf '%s\n' "$layout" || printf 'grid\n'
}

session_uses_per_window_layout() {
  [[ "$(session_layout_value "$1")" == "per-window" ]]
}

