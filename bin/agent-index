#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: agent-index [--session NAME] [--limit N] [--agent NAME] [--follow] [--json] [--chat]

Shows indexed agent-send messages for the current session.
EOF
}

SESSION_NAME="${MULTIAGENT_SESSION:-}"
LIMIT=50
JSON_MODE=0
FOLLOW_MODE=0
CHAT_MODE=0
FILTER_AGENT=""

available_agents() {
  local agents=() agent upper pane log_file
  for agent in claude codex gemini copilot; do
    upper="$(printf '%s' "$agent" | tr '[:lower:]' '[:upper:]')"
    pane="$(tmux show-environment -t "$SESSION_NAME" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    if [[ -n "$pane" ]]; then
      agents+=("$agent")
      continue
    fi
    log_file="${SESSION_LOG_DIR}/${agent}.log"
    [[ -f "$log_file" ]] && agents+=("$agent")
  done
  if [[ ${#agents[@]} -eq 0 ]]; then
    agents=(claude codex gemini copilot)
  fi
  printf '%s\n' "$(IFS=,; echo "${agents[*]}")"
}

resolve_session_log_dir() {
  local log_dir="${MULTIAGENT_LOG_DIR:-}"
  local created_epoch created_key updated_key existing_dir session_dir
  if [[ -z "$log_dir" && -n "$SESSION_NAME" ]]; then
    log_dir="$(tmux show-environment -t "$SESSION_NAME" MULTIAGENT_LOG_DIR 2>/dev/null | sed 's/^[^=]*=//' || true)"
  fi
  if [[ -z "$log_dir" ]]; then
    log_dir="${MULTIAGENT_WORKSPACE:-$PWD}/logs-dev"
  fi
  created_epoch="$(tmux display-message -p -t "$SESSION_NAME" '#{session_created}' 2>/dev/null || true)"
  if [[ -n "$created_epoch" ]]; then
    created_key="$(date -r "$created_epoch" '+%y%m%d' 2>/dev/null || date '+%y%m%d')"
  else
    created_key="$(date '+%y%m%d')"
  fi
  updated_key="$(date '+%y%m%d')"
  existing_dir="$(find "$log_dir" -maxdepth 1 -type d -name "${SESSION_NAME}_${created_key}_*" | head -n 1)"
  if [[ -z "$existing_dir" ]]; then
    existing_dir="$(find "$log_dir" -maxdepth 1 -type d -name "${SESSION_NAME}_*" | sort | tail -n 1)"
  fi
  if [[ -z "$existing_dir" ]]; then
    existing_dir="$(find "${MULTIAGENT_WORKSPACE:-$PWD}" -maxdepth 3 -type d -name "${SESSION_NAME}_*" | sort | tail -n 1)"
  fi
  session_dir="${log_dir}/${SESSION_NAME}_${created_key}_${updated_key}"
  if [[ -n "$existing_dir" ]] && [[ "$existing_dir" != "$session_dir" ]]; then
    printf '%s\n' "$existing_dir"
  else
    printf '%s\n' "$session_dir"
  fi
}

session_workspace_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_WORKSPACE 2>/dev/null | sed 's/^[^=]*=//' || true
}

resolve_session_name() {
  local matched=()
  if [[ -n "$SESSION_NAME" ]]; then
    printf '%s\n' "$SESSION_NAME"
    return 0
  fi

  if [[ -n "${TMUX:-}" ]]; then
    SESSION_NAME="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
    if [[ -n "$SESSION_NAME" ]]; then
      printf '%s\n' "$SESSION_NAME"
      return 0
    fi
  fi

  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    [[ "$(session_workspace_value "$session")" == "$PWD" ]] && matched+=("$session")
  done < <(tmux list-sessions -F '#S' 2>/dev/null || true)

  if [[ ${#matched[@]} -eq 1 ]]; then
    printf '%s\n' "${matched[0]}"
    return 0
  fi

  if [[ ${#matched[@]} -gt 1 ]]; then
    echo "Multiple sessions exist for this workspace; specify --session." >&2
    return 1
  fi

  echo "No active multiagent session found for this workspace." >&2
  return 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --session) SESSION_NAME="$2"; shift 2 ;;
    --limit)   LIMIT="$2"; shift 2 ;;
    --agent)   FILTER_AGENT="$2"; shift 2 ;;
    --follow)  FOLLOW_MODE=1; shift ;;
    --json)    JSON_MODE=1; shift ;;
    --chat)    CHAT_MODE=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage >&2; exit 1 ;;
  esac
done

SESSION_NAME="$(resolve_session_name)"
SESSION_LOG_DIR="$(resolve_session_log_dir)"
INDEX_FILE="${SESSION_LOG_DIR}/.agent-index.jsonl"
if [[ ! -f "$INDEX_FILE" ]]; then
  INDEX_FILE="$(find "${MULTIAGENT_WORKSPACE:-$PWD}" -maxdepth 4 -path "*/${SESSION_NAME}_*/.agent-index.jsonl" | sort | tail -n 1)"
fi

if [[ ! -f "$INDEX_FILE" && "$CHAT_MODE" -eq 1 ]]; then
  INDEX_FILE="${SESSION_LOG_DIR}/.agent-index.jsonl"
fi

if [[ ! -f "$INDEX_FILE" && "$CHAT_MODE" -ne 1 ]]; then
  echo "No indexed messages found for session: $SESSION_NAME"
  exit 0
fi

if [[ "$CHAT_MODE" -eq 1 ]]; then
  CHAT_TARGETS="$(available_agents)"
  CHAT_PORT="$(python3 - <<'PYEOF'
import socket
s = socket.socket()
s.bind(("127.0.0.1", 0))
print(s.getsockname()[1])
s.close()
PYEOF
)"
  CHAT_LOG="$(mktemp "${TMPDIR:-/tmp}/agent-index-chat.${SESSION_NAME}.XXXXXX")"
  CHAT_LOG="${CHAT_LOG}.log"
  CHAT_SERVER_SCRIPT="$(mktemp "${TMPDIR:-/tmp}/agent-index-chat-server.${SESSION_NAME}.XXXXXX")"
  CHAT_SERVER_SCRIPT="${CHAT_SERVER_SCRIPT}.py"
  CHAT_LOG_DIR="$(dirname "$SESSION_LOG_DIR")"
  cat > "$CHAT_SERVER_SCRIPT" <<'PYEOF'
import html
import json
import os
import subprocess
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, urlparse

index_path = Path(sys.argv[1])
limit = int(sys.argv[2])
filter_agent = sys.argv[3].strip().lower()
session_name = sys.argv[4]
follow_mode = sys.argv[5] == "1"
port = int(sys.argv[6])
agent_send_path = sys.argv[7]
workspace = sys.argv[8]
log_dir = sys.argv[9]
targets = [item for item in sys.argv[10].split(",") if item]

def matches(entry):
    if not filter_agent:
        return True
    if entry.get("sender", "").lower() == filter_agent:
        return True
    return any(t.lower() == filter_agent for t in entry.get("targets", []))

def read_entries():
    if not index_path.exists():
        return []
    entries = []
    with index_path.open() as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            entry = json.loads(line)
            if matches(entry):
                entries.append(entry)
    return entries[-limit:]

def payload():
    return json.dumps({
        "session": session_name,
        "filter": filter_agent or "all",
        "follow": follow_mode,
        "source": str(index_path),
        "targets": targets,
        "entries": read_entries(),
    }, ensure_ascii=True).encode("utf-8")

def send_message(target, message):
    target = (target or "").strip()
    message = (message or "").strip()
    if not target:
        return 400, {"ok": False, "error": "target is required"}
    if not message:
        return 400, {"ok": False, "error": "message is required"}
    env = os.environ.copy()
    env["MULTIAGENT_SESSION"] = session_name
    env["MULTIAGENT_WORKSPACE"] = workspace
    env["MULTIAGENT_LOG_DIR"] = log_dir
    env["MULTIAGENT_BIN_DIR"] = str(Path(agent_send_path).parent)
    try:
        result = subprocess.run(
            [agent_send_path, target, message],
            capture_output=True,
            text=True,
            env=env,
            check=False,
        )
    except Exception as exc:
        return 500, {"ok": False, "error": str(exc)}
    if result.returncode != 0:
        return 400, {"ok": False, "error": (result.stderr or result.stdout or "agent-send failed").strip()}
    return 200, {"ok": True}

HTML = """<!doctype html>
<html lang="en">
<head>
