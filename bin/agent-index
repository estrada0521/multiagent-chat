#!/usr/bin/env bash

set -euo pipefail

_HERE="${BASH_SOURCE[0]:-$0}"
while [[ -L "$_HERE" ]]; do
  _D="$(cd "$(dirname "$_HERE")" && pwd)"
  _T="$(readlink "$_HERE")"
  [[ "$_T" == /* ]] || _T="$_D/$_T"
  _HERE="$_T"
done
_REAL_SCRIPT="$_HERE"
SCRIPT_DIR="$(cd "$(dirname "$_REAL_SCRIPT")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
AGENT_INDEX_PYTHONPATH="${REPO_ROOT}/lib:${REPO_ROOT}${PYTHONPATH:+:${PYTHONPATH}}"

if [[ "${MULTIAGENT_SKIP_DEPS_CHECK:-}" != "1" ]]; then
  if ! command -v python3 >/dev/null 2>&1 || ! command -v tmux >/dev/null 2>&1; then
    bash "$SCRIPT_DIR/ensure-multiagent-deps" || exit 1
  fi
fi

_ALL_AGENTS="$(PYTHONPATH="$AGENT_INDEX_PYTHONPATH" python3 -c "from agent_index.agent_registry import ALL_AGENT_NAMES; print(' '.join(ALL_AGENT_NAMES))" 2>/dev/null || echo "claude codex gemini kimi copilot cursor grok opencode qwen aider")"
read -ra _ALL_AGENTS_ARR <<< "$_ALL_AGENTS"

default_tmux_socket_name() {
  python3 - "$REPO_ROOT" <<'PYEOF'
import hashlib
import os
import sys

root = os.path.realpath(sys.argv[1])
digest = hashlib.sha1(root.encode("utf-8")).hexdigest()[:12]
print(f"multiagent-{digest}")
PYEOF
}

TMUX_SOCKET_NAME="${MULTIAGENT_TMUX_SOCKET:-$(default_tmux_socket_name)}"

tmux() {
  if [[ "$TMUX_SOCKET_NAME" == */* ]]; then
    command tmux -S "$TMUX_SOCKET_NAME" "$@"
  else
    command tmux -L "$TMUX_SOCKET_NAME" "$@"
  fi
}

usage() {
  cat <<'EOF'
Usage: agent-index [--session NAME] [--limit N] [--agent NAME] [--follow] [--json] [--chat] [--hub] [--hub-port N]

Shows indexed chat/event messages for the current or archived session.
EOF
}

SESSION_NAME="${MULTIAGENT_SESSION:-}"
LIMIT=2000
JSON_MODE=0
FOLLOW_MODE=0
CHAT_MODE=0
HUB_MODE=0
HTTPS_MODE=0
HUB_PORT="${AGENT_INDEX_HUB_PORT:-8788}"
NO_OPEN=0
FILTER_AGENT=""
SESSION_WORKSPACE="${MULTIAGENT_WORKSPACE:-$PWD}"
SESSION_IS_ACTIVE=0

realpath_or_echo() {
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1" 2>/dev/null || printf '%s\n' "$1"
}

detect_local_ip() {
  python3 - <<'PYEOF'
import socket

sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
try:
    sock.connect(("8.8.8.8", 80))
    print(sock.getsockname()[0])
except OSError:
    pass
finally:
    sock.close()
PYEOF
}

detect_local_host_name() {
  local local_name=""
  if command -v scutil >/dev/null 2>&1; then
    local_name="$(scutil --get LocalHostName 2>/dev/null || true)"
  fi
  if [[ -z "$local_name" ]]; then
    local_name="$(hostname 2>/dev/null || true)"
    local_name="${local_name%%.*}"
  fi
  printf '%s\n' "$local_name"
}

read_local_https_extra_names() {
  local extra_names_file="$REPO_ROOT/certs/local-https-extra-names.txt"
  local line=""
  [[ -f "$extra_names_file" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="${line//$'\r'/}"
    line="$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    [[ -n "$line" ]] || continue
    printf '%s\n' "$line"
  done < "$extra_names_file"
}

cert_has_san_entry() {
  local cert_file="$1"
  local san_kind="$2"
  local san_value="$3"
  python3 - "$cert_file" "$san_kind" "$san_value" <<'PYEOF'
import ssl
import sys
import ipaddress

cert_file, san_kind, san_value = sys.argv[1:4]
try:
    decoded = ssl._ssl._test_decode_cert(cert_file)
except Exception:
    sys.exit(1)

for entry_kind, entry_value in decoded.get("subjectAltName", ()):
    if entry_kind != san_kind:
        continue
    if san_kind == "IP Address":
        try:
            if ipaddress.ip_address(entry_value) == ipaddress.ip_address(san_value):
                sys.exit(0)
        except ValueError:
            pass
        continue
    if entry_value == san_value:
        sys.exit(0)
sys.exit(1)
PYEOF
}

ensure_repo_https_cert() {
  local cert_file="$REPO_ROOT/certs/cert.pem"
  local key_file="$REPO_ROOT/certs/key.pem"
  local archive_dir="$REPO_ROOT/certs/archive"
  local current_ip local_name ts
  local required_missing=0
  local names=()
  local extra_name=""
  local name

  command -v mkcert >/dev/null 2>&1 || return 0

  current_ip="$(detect_local_ip || true)"
  local_name="$(detect_local_host_name)"

  names=("localhost" "127.0.0.1" "::1")
  [[ -n "$current_ip" ]] && names+=("$current_ip")
  if [[ -n "$local_name" ]]; then
    names+=("$local_name")
    [[ "$local_name" != *.local ]] && names+=("${local_name}.local")
  fi
  while IFS= read -r extra_name; do
    [[ -n "$extra_name" ]] || continue
    names+=("$extra_name")
  done < <(read_local_https_extra_names)

  if [[ -f "$cert_file" && -f "$key_file" ]]; then
    for name in "${names[@]}"; do
      if [[ "$name" == *:* || "$name" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        cert_has_san_entry "$cert_file" "IP Address" "$name" || required_missing=1
      else
        cert_has_san_entry "$cert_file" "DNS" "$name" || required_missing=1
      fi
      [[ "$required_missing" -eq 0 ]] || break
    done
  else
    required_missing=1
  fi

  if [[ "$required_missing" -eq 1 ]]; then
    mkdir -p "$archive_dir"
    ts="$(date +%Y%m%d-%H%M%S)"
    [[ -f "$cert_file" ]] && cp "$cert_file" "$archive_dir/cert.pem.${ts}"
    [[ -f "$key_file" ]] && cp "$key_file" "$archive_dir/key.pem.${ts}"
    mkcert -cert-file "$cert_file" -key-file "$key_file" "${names[@]}" >/dev/null
  fi

  if [[ -f "$cert_file" && -f "$key_file" ]]; then
    export MULTIAGENT_CERT_FILE="$cert_file"
    export MULTIAGENT_KEY_FILE="$key_file"
  fi
}

# macOS: open -a Safari は新規ウィンドウになりやすい。前面ウィンドウにタブを足すだけにする。
open_url_in_safari_front_window_tab() {
  local chat_url="$1"
  [[ "$(uname -s)" == "Darwin" ]] || return 1
  command -v osascript >/dev/null 2>&1 || return 1
  /usr/bin/osascript - "$chat_url" <<'OSA' >/dev/null 2>&1
on run argv
  set targetURL to item 1 of argv as text
  tell application "Safari"
    if not running then launch
    delay 0.2
    activate
    if (count of windows) is 0 then
      make new document
      set URL of current tab of front window to targetURL
    else
      tell front window
        set current tab to (make new tab with properties {URL:targetURL})
      end tell
    end if
  end tell
end run
OSA
}

open_chat_window() {
  local chat_url="$1"
  # Google Chrome を明示したい場合だけ MULTIAGENT_OPEN_WITH_CHROME=1（既定では起動しない）。
  if [[ "${MULTIAGENT_OPEN_WITH_CHROME:-0}" == "1" ]]; then
    local chrome_app="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
    if [[ "${MULTIAGENT_OPEN_CHAT_REUSE:-1}" != "0" && "$(uname -s)" == "Darwin" ]] && command -v open >/dev/null 2>&1; then
      if pgrep -qf "Google Chrome\\.app" >/dev/null 2>&1; then
        open -a "Google Chrome" "$chat_url" >/dev/null 2>&1 && return 0
      fi
    fi
    if [[ -x "$chrome_app" ]]; then
      nohup "$chrome_app" --app="$chat_url" --window-size=720,920 >/dev/null 2>&1 </dev/null &
      disown || true
      return 0
    fi
  fi

  if command -v open >/dev/null 2>&1; then
    # macOS: Safari は AppleScript で前面ウィンドウにタブ追加（open -a Safari は別ウィンドウになりやすい）。
    # 自動化未許可などで AppleScript が失敗したら open（既定ブラウザ）には落とさない — 既定が Chrome だと別ウィンドウの Chrome が開いてしまうため。
    # 既定ブラウザで開きたいときは MULTIAGENT_OPEN_WITH_SAFARI=0。
    if [[ "$(uname -s)" == "Darwin" && "${MULTIAGENT_OPEN_WITH_SAFARI:-1}" != "0" && -d "/Applications/Safari.app" ]]; then
      if open_url_in_safari_front_window_tab "$chat_url"; then
        return 0
      fi
      printf '%s\n' "agent-index: Safari で URL を開けませんでした。システム設定 → プライバシーとセキュリティ → 自動化 で、この端末（または Cursor）から Safari を許可するか、次を手で開いてください: $chat_url" >&2
      return 1
    fi
    open "$chat_url" >/dev/null 2>&1 || true
    return 0
  fi

  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$chat_url" >/dev/null 2>&1 || true
    return 0
  fi

  return 1
}

port_serves_expected_url() {
  local scheme="$1"
  local port="$2"
  local path="$3"
  python3 - "$scheme" "$port" "$path" <<'PYEOF'
import http.client
import ssl
import sys

scheme = sys.argv[1]
port = int(sys.argv[2])
path = sys.argv[3]

try:
    if scheme == "https":
        conn = http.client.HTTPSConnection(
            "127.0.0.1",
            port,
            timeout=1.2,
            context=ssl._create_unverified_context(),
        )
    else:
        conn = http.client.HTTPConnection("127.0.0.1", port, timeout=1.2)
    conn.request("GET", path, headers={"Host": f"127.0.0.1:{port}"})
    resp = conn.getresponse()
    resp.read(1)
    conn.close()
    if 200 <= resp.status < 500:
        sys.exit(0)
except Exception:
    pass
sys.exit(1)
PYEOF
}

list_listening_pids() {
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true
    return 0
  fi
  if command -v fuser >/dev/null 2>&1; then
    fuser "$port"/tcp 2>/dev/null | tr ' ' '\n' | sed '/^$/d' || true
    return 0
  fi
  return 0
}

pid_listens_on_port() {
  local pid="$1"
  local port="$2"
  [[ -n "$pid" && -n "$port" ]] || return 1
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -a -p "$pid" -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
    return $?
  fi
  local seen
  seen="$(list_listening_pids "$port" | tr '\n' ' ')"
  [[ " $seen " == *" $pid "* ]]
}

wait_for_port_to_clear() {
  local port="$1"
  local attempts="${2:-50}"
  local delay="${3:-0.1}"
  local listeners
  local i
  for i in $(seq 1 "$attempts"); do
    listeners="$(list_listening_pids "$port")"
    if [[ -z "${listeners//[[:space:]]/}" ]]; then
      return 0
    fi
    sleep "$delay"
  done
  return 1
}

repo_log_roots() {
  local roots=() candidate resolved existing
  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    resolved="$(realpath_or_echo "$candidate")"
    existing=0
    for candidate in "${roots[@]:-}"; do
      if [[ "$candidate" == "$resolved" ]]; then
        existing=1
        break
      fi
    done
    [[ "$existing" -eq 1 ]] || roots+=("$resolved")
  done < <(active_repo_log_roots)
  for candidate in \
    "${MULTIAGENT_LOG_DIR:-}" \
    "${MULTIAGENT_WORKSPACE:-}/logs" \
    "${REPO_ROOT}/logs"
  do
    [[ -n "$candidate" ]] || continue
    resolved="$(realpath_or_echo "$candidate")"
    existing=0
    for candidate in "${roots[@]:-}"; do
      if [[ "$candidate" == "$resolved" ]]; then
        existing=1
        break
      fi
    done
    [[ "$existing" -eq 1 ]] || roots+=("$resolved")
  done
  printf '%s\n' "${roots[@]}"
}

active_repo_log_roots() {
  local session workspace log_dir bin_dir
  while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    bin_dir="$(session_bin_dir_value "$session")"
    [[ -n "$bin_dir" ]] || continue
    bin_dir="$(realpath_or_echo "$bin_dir")"
    [[ "$bin_dir" == "$SCRIPT_DIR" ]] || continue
    log_dir="$(session_log_dir_value "$session")"
    [[ -n "$log_dir" ]] && printf '%s\n' "$log_dir"
    workspace="$(session_workspace_value "$session")"
    [[ -n "$workspace" ]] && printf '%s\n' "${workspace}/logs"
  done < <(tmux list-sessions -F '#S' 2>/dev/null || true)
}

find_archived_index_files() {
  local session_filter="${1:-}" root
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    if [[ -n "$session_filter" ]]; then
      find "$root" -maxdepth 2 -type f -path "*/${session_filter}_*/.agent-index.jsonl" 2>/dev/null
    else
      find "$root" -maxdepth 2 -type f -name '.agent-index.jsonl' 2>/dev/null
    fi
  done < <(repo_log_roots)
}

latest_archived_index_file() {
  local session_filter="${1:-}"
  find_archived_index_files "$session_filter" | sort | tail -n 1
}

matching_archived_sessions() {
  local index_file dir base session
  while IFS= read -r index_file; do
    [[ -n "$index_file" ]] || continue
    dir="$(basename "$(dirname "$index_file")")"
    base="${dir%_*}"
    session="${base%_*}"
    [[ -n "$session" ]] && printf '%s\n' "$session"
  done < <(find_archived_index_files)
}

available_agents() {
  local agents_str
  agents_str="$(tmux show-environment -t "$SESSION_NAME" MULTIAGENT_AGENTS 2>/dev/null | sed 's/^[^=]*=//' || true)"
  if [[ -n "$agents_str" ]]; then
    printf '%s\n' "$agents_str"
    return
  fi
  # Fallback for old sessions
  local agents=() agent upper pane log_file
  for agent in "${_ALL_AGENTS_ARR[@]}"; do
    upper="$(printf '%s' "$agent" | tr '[:lower:]' '[:upper:]')"
    pane="$(tmux show-environment -t "$SESSION_NAME" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    if [[ -n "$pane" ]]; then
      agents+=("$agent")
      continue
    fi
    log_file="${SESSION_LOG_DIR}/${agent}.log"
    [[ -f "$log_file" ]] && agents+=("$agent")
  done
  printf '%s\n' "$(IFS=,; echo "${agents[*]}")"
}

resolve_session_log_dir() {
  local log_dir="${MULTIAGENT_LOG_DIR:-}"
  local index_path="${MULTIAGENT_INDEX_PATH:-}"
  local created_epoch created_key updated_key existing_dir session_dir
  local repo_session_dir="${REPO_ROOT}/logs/${SESSION_NAME}"
  if [[ -z "$index_path" && -n "$SESSION_NAME" ]]; then
    index_path="$(tmux show-environment -t "$SESSION_NAME" MULTIAGENT_INDEX_PATH 2>/dev/null | sed 's/^[^=]*=//' || true)"
  fi
  if [[ -n "$index_path" ]]; then
    mkdir -p "$(dirname "$index_path")"
    printf '%s\n' "$(dirname "$index_path")"
    return
  fi
  if [[ -z "$log_dir" && -n "$SESSION_NAME" ]]; then
    log_dir="$(tmux show-environment -t "$SESSION_NAME" MULTIAGENT_LOG_DIR 2>/dev/null | sed 's/^[^=]*=//' || true)"
  fi
  if [[ -d "$repo_session_dir" ]]; then
    printf '%s\n' "$repo_session_dir"
    return
  fi
  if [[ -z "$log_dir" ]]; then
    log_dir="${SESSION_WORKSPACE:-${MULTIAGENT_WORKSPACE:-}}/logs"
  fi
  if [[ "$log_dir" == "/logs" || -z "$log_dir" ]]; then
    log_dir="${REPO_ROOT}/logs"
  fi
  session_dir="${log_dir}/${SESSION_NAME}"
  if [[ -d "$session_dir" ]]; then
    printf '%s\n' "$session_dir"
    return
  fi
  # Fallback: look for old dated-directory format, prefer largest .agent-index.jsonl
  existing_dir=""
  while IFS= read -r jsonl; do
    [[ -f "$jsonl" ]] || continue
    dir="$(dirname "$jsonl")"
    if [[ -z "$existing_dir" ]]; then
      existing_dir="$dir"
    else
      [[ $(wc -c < "$jsonl") -gt $(wc -c < "${existing_dir}/.agent-index.jsonl") ]] && existing_dir="$dir"
    fi
  done < <(find "$log_dir" -maxdepth 2 -name ".agent-index.jsonl" -path "*/${SESSION_NAME}_*" 2>/dev/null)
  if [[ -z "$existing_dir" ]]; then
    existing_dir="$(find "$log_dir" -maxdepth 1 -type d -name "${SESSION_NAME}_*" 2>/dev/null | sort | tail -n 1)"
  fi
  if [[ -z "$existing_dir" ]]; then
    existing_dir="$(find "${MULTIAGENT_WORKSPACE:-$PWD}" -maxdepth 3 -type d -name "${SESSION_NAME}_*" 2>/dev/null | sort | tail -n 1)"
  fi
  if [[ -n "$existing_dir" ]]; then
    printf '%s\n' "$existing_dir"
  else
    printf '%s\n' "$session_dir"
  fi
}

session_workspace_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_WORKSPACE 2>/dev/null | sed 's/^[^=]*=//' || true
}

session_log_dir_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_LOG_DIR 2>/dev/null | sed 's/^[^=]*=//' || true
}

session_index_path_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_INDEX_PATH 2>/dev/null | sed 's/^[^=]*=//' || true
}

session_bin_dir_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_BIN_DIR 2>/dev/null | sed 's/^[^=]*=//' || true
}

matching_repo_sessions() {
  local session bin_dir
  while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    bin_dir="$(session_bin_dir_value "$session")"
    [[ -n "$bin_dir" ]] || continue
    bin_dir="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$bin_dir" 2>/dev/null || printf '%s' "$bin_dir")"
    [[ "$bin_dir" == "$SCRIPT_DIR" ]] || continue
    printf '%s\n' "$session"
  done < <(tmux list-sessions -F '#S' 2>/dev/null || true)
}

resolve_session_name() {
  local matched=()
  if [[ -n "$SESSION_NAME" ]]; then
    printf '%s\n' "$SESSION_NAME"
    return 0
  fi

  if [[ -n "${TMUX:-}" ]]; then
    SESSION_NAME="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
    if [[ -n "$SESSION_NAME" ]]; then
      printf '%s\n' "$SESSION_NAME"
      return 0
    fi
  fi

  matched=()
  while IFS= read -r session; do
    [[ -n "$session" ]] && matched+=("$session")
  done < <(matching_repo_sessions)

  if [[ ${#matched[@]} -eq 1 ]]; then
    printf '%s\n' "${matched[0]}"
    return 0
  fi

  if [[ ${#matched[@]} -gt 1 ]]; then
    echo "Multiple active multiagent sessions exist; specify --session." >&2
    return 1
  fi

  matched=()
  while IFS= read -r session; do
    [[ -n "$session" ]] && matched+=("$session")
  done < <(matching_archived_sessions | sort -u)

  if [[ ${#matched[@]} -eq 1 ]]; then
    printf '%s\n' "${matched[0]}"
    return 0
  fi

  if [[ ${#matched[@]} -gt 1 ]]; then
    echo "Multiple archived multiagent sessions exist; specify --session." >&2
    return 1
  fi

  echo "No active or archived multiagent session found for this workspace." >&2
  return 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --session) SESSION_NAME="$2"; shift 2 ;;
    --limit)   LIMIT="$2"; shift 2 ;;
    --agent)   FILTER_AGENT="$2"; shift 2 ;;
    --follow)  FOLLOW_MODE=1; shift ;;
    --json)    JSON_MODE=1; shift ;;
    --chat)    CHAT_MODE=1; shift ;;
    --hub)     HUB_MODE=1; shift ;;
    --hub-port) HUB_PORT="$2"; shift 2 ;;
    --no-open) NO_OPEN=1; shift ;;
    --https) HTTPS_MODE=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage >&2; exit 1 ;;
  esac
done

# Auto-detect or enable HTTPS certs
if [[ "$HTTPS_MODE" -eq 1 ]]; then
  export MULTIAGENT_ENABLE_LOCAL_HTTPS=1
  unset MULTIAGENT_DISABLE_LOCAL_HTTPS
fi
if [[ "${MULTIAGENT_DISABLE_LOCAL_HTTPS:-0}" == "1" ]]; then
  unset MULTIAGENT_CERT_FILE
  unset MULTIAGENT_KEY_FILE
elif [[ -z "${MULTIAGENT_CERT_FILE:-}" ]]; then
  ensure_repo_https_cert
fi
if [[ -z "${MULTIAGENT_PUBLIC_HOST:-}" ]] && [[ -f "$REPO_ROOT/certs/public-host.txt" ]]; then
  export MULTIAGENT_PUBLIC_HOST="$(tr -d '\r\n' < "$REPO_ROOT/certs/public-host.txt")"
fi
if [[ -z "${MULTIAGENT_PUBLIC_HUB_PORT:-}" ]]; then
  export MULTIAGENT_PUBLIC_HUB_PORT="443"
fi
HTTPS_SCHEME="http"
if [[ -n "${MULTIAGENT_CERT_FILE:-}" ]]; then
  HTTPS_SCHEME="https"
fi

if [[ "$HUB_MODE" -eq 1 ]]; then
  HUB_LOG="$(mktemp "${TMPDIR:-/tmp}/agent-index-hub.XXXXXX")"
  HUB_LOG="${HUB_LOG}.log"
  HUB_READY=0
  if port_serves_expected_url "$HTTPS_SCHEME" "$HUB_PORT" "/hub.webmanifest"
  then
    HUB_READY=1
  else
    PYTHONPATH="$AGENT_INDEX_PYTHONPATH" MULTIAGENT_AGENT_NAME="user" nohup python3 -m agent_index.hub_server "$REPO_ROOT" "$SCRIPT_DIR/agent-index" "$HUB_PORT" "$TMUX_SOCKET_NAME" >"$HUB_LOG" 2>&1 </dev/null &
    HUB_SERVER_PID=$!
    disown "$HUB_SERVER_PID" || true
    for _ in $(seq 1 50); do
      if port_serves_expected_url "$HTTPS_SCHEME" "$HUB_PORT" "/hub.webmanifest"
      then
        HUB_READY=1
        break
      fi
      if ! kill -0 "$HUB_SERVER_PID" 2>/dev/null; then
        break
      fi
      sleep 0.1
    done
  fi

  if [[ "$HUB_READY" -ne 1 ]]; then
    echo "Hub server failed to start or a stale server with the wrong scheme is still listening on port $HUB_PORT. Check log: $HUB_LOG" >&2
    exit 1
  fi

  HUB_URL="${HTTPS_SCHEME}://127.0.0.1:${HUB_PORT}/"
  LOCAL_IP="$(detect_local_ip || true)"
  [[ "$NO_OPEN" -eq 0 ]] && { open_chat_window "$HUB_URL" || true; }
  echo "Hub:                $HUB_URL"
  if [[ -n "$LOCAL_IP" ]]; then
    echo "Hub (LAN / phone): ${HTTPS_SCHEME}://${LOCAL_IP}:${HUB_PORT}/"
  else
    echo "Tip (phone): open Hub using this Mac's LAN IP instead of 127.0.0.1 (same Wi‑Fi)."
  fi
  echo "From Hub: New Session, Resume, Settings, … — see README if HTTPS warns on iPhone."
  exit 0
fi

SESSION_NAME="$(resolve_session_name)"
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  SESSION_IS_ACTIVE=1
fi
if [[ "$SESSION_IS_ACTIVE" -eq 1 ]]; then
  SESSION_WORKSPACE="$(session_workspace_value "$SESSION_NAME")"
fi
if [[ -z "$SESSION_WORKSPACE" ]]; then
  SESSION_WORKSPACE="${MULTIAGENT_WORKSPACE:-$REPO_ROOT}"
fi
SESSION_LOG_DIR="$(resolve_session_log_dir)"
INDEX_FILE="${SESSION_LOG_DIR}/.agent-index.jsonl"
if [[ ! -f "$INDEX_FILE" ]]; then
  INDEX_FILE="$(latest_archived_index_file "$SESSION_NAME" || true)"
fi

if [[ ! -f "$INDEX_FILE" && "$CHAT_MODE" -eq 1 ]]; then
  INDEX_FILE="${SESSION_LOG_DIR}/.agent-index.jsonl"
fi

if [[ ! -f "$INDEX_FILE" && "$CHAT_MODE" -ne 1 ]]; then
  echo "No indexed messages found for session: $SESSION_NAME"
  exit 0
fi

if [[ "$CHAT_MODE" -eq 1 ]]; then
  CHAT_TARGETS="$(available_agents)"
  CHAT_PORT="$(PYTHONPATH="$AGENT_INDEX_PYTHONPATH" python3 -m agent_index.chat_port_cli "$REPO_ROOT" "$SESSION_NAME")"
  CHAT_LOG="$(mktemp "${TMPDIR:-/tmp}/agent-index-chat.${SESSION_NAME}.XXXXXX")"
  CHAT_LOG="${CHAT_LOG}.log"
  CHAT_LOG_DIR="$(dirname "$SESSION_LOG_DIR")"
  # Kill only the stale listener on the chat port, not clients currently connected to it.
  STALE_CHAT_PIDS="$(list_listening_pids "$CHAT_PORT")"
  if [[ -n "${STALE_CHAT_PIDS//[[:space:]]/}" ]]; then
    printf '%s\n' "$STALE_CHAT_PIDS" | xargs kill -9 2>/dev/null || true
    wait_for_port_to_clear "$CHAT_PORT" 50 0.1 || true
  fi
  SESSION_IS_ACTIVE="$SESSION_IS_ACTIVE" PYTHONPATH="$AGENT_INDEX_PYTHONPATH" MULTIAGENT_AGENT_NAME="user" nohup python3 -m agent_index.chat_server "$INDEX_FILE" "$LIMIT" "$FILTER_AGENT" "$SESSION_NAME" "$FOLLOW_MODE" "$CHAT_PORT" "$SCRIPT_DIR/agent-send" "$SESSION_WORKSPACE" "$CHAT_LOG_DIR" "$CHAT_TARGETS" "$TMUX_SOCKET_NAME" "$HUB_PORT" >"$CHAT_LOG" 2>&1 </dev/null &
  CHAT_SERVER_PID=$!
  disown "$CHAT_SERVER_PID" || true
  CHAT_READY=0
  for _ in $(seq 1 50); do
    if pid_listens_on_port "$CHAT_SERVER_PID" "$CHAT_PORT" && port_serves_expected_url "$HTTPS_SCHEME" "$CHAT_PORT" "/app.webmanifest"
    then
      CHAT_READY=1
      break
    fi
    if ! kill -0 "$CHAT_SERVER_PID" 2>/dev/null; then
      break
    fi
    sleep 0.1
  done
  if [[ "$CHAT_READY" -ne 1 ]]; then
    echo "Chat server failed to start or a stale server with the wrong scheme is still listening on port $CHAT_PORT. Check log: $CHAT_LOG" >&2
    exit 1
  fi
  CHAT_URL="${HTTPS_SCHEME}://127.0.0.1:${CHAT_PORT}/?follow=1"
  LOCAL_IP="$(detect_local_ip || true)"
  [[ "$NO_OPEN" -eq 0 ]] && { open_chat_window "$CHAT_URL" || true; }
  echo "Opened chat view: $CHAT_URL"
  if [[ -n "$LOCAL_IP" ]]; then
    echo "Network access:   ${HTTPS_SCHEME}://${LOCAL_IP}:${CHAT_PORT}/?follow=1"
  fi
  echo "Log file:         $INDEX_FILE"
  exit 0
fi

PYTHONPATH="$AGENT_INDEX_PYTHONPATH" python3 -m agent_index.index_viewer "$INDEX_FILE" "$LIMIT" "$FILTER_AGENT" "$JSON_MODE" "$FOLLOW_MODE"
