#!/usr/bin/env bash
set -euo pipefail

_HERE="${BASH_SOURCE[0]:-$0}"
while [[ -L "$_HERE" ]]; do
  _D="$(cd "$(dirname "$_HERE")" && pwd)"
  _T="$(readlink "$_HERE")"
  [[ "$_T" == /* ]] || _T="$_D/$_T"
  _HERE="$_T"
done
_BIN="$(cd "$(dirname "$_HERE")" && pwd)"
REPO_ROOT="$(cd "$_BIN/.." && pwd)"

exec bash "$REPO_ROOT/auto_mode/monitor" "$@"
