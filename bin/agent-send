#!/usr/bin/env bash

set -euo pipefail

_REAL_SCRIPT="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0" 2>/dev/null || echo "$0")"
SCRIPT_DIR="$(cd "$(dirname "$_REAL_SCRIPT")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [[ -n "${PYTHONPATH:-}" ]]; then
  export PYTHONPATH="${REPO_ROOT}/src:${REPO_ROOT}:${PYTHONPATH}"
else
  export PYTHONPATH="${REPO_ROOT}/src:${REPO_ROOT}"
fi

exec python3 -m multiagent_chat.agent_send_cli --repo-root "$REPO_ROOT" --script-dir "$SCRIPT_DIR" "$@"
