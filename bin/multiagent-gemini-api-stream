#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from lib.agent_index.gemini_direct import (
    DEFAULT_MODEL,
    GeminiRequest,
    event_jsonl_line,
    read_prompt_text,
    run_gemini_event_stream,
)


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="Stream Gemini Developer API responses with only stdlib dependencies."
    )
    p.add_argument("prompt", nargs="*", help="Prompt text. If omitted, stdin is used.")
    p.add_argument("--model", default=DEFAULT_MODEL, help=f"Gemini model name (default: {DEFAULT_MODEL})")
    p.add_argument("--system", default="", help="Optional system instruction text.")
    p.add_argument("--temperature", type=float, default=None, help="Optional generationConfig.temperature")
    p.add_argument(
        "--max-output-tokens",
        type=int,
        default=None,
        help="Optional generationConfig.maxOutputTokens",
    )
    p.add_argument(
        "--format",
        choices=("text", "jsonl", "raw"),
        default="text",
        help="Output text only, normalized jsonl, or raw SSE lines.",
    )
    p.add_argument(
        "--api-key-env",
        default="",
        help="Optional env var name to read the API key from before trying GEMINI_API_KEY/GOOGLE_API_KEY.",
    )
    return p.parse_args()

def stream_request(prompt: str, args: argparse.Namespace) -> int:
    request = GeminiRequest(
        model=args.model,
        system=args.system,
        temperature=args.temperature,
        max_output_tokens=args.max_output_tokens,
        api_key_env=args.api_key_env,
        include_raw_payload=(args.format == "jsonl"),
    )
    saw_text = False

    def on_event(event: dict) -> None:
        nonlocal saw_text
        if args.format == "jsonl":
            sys.stdout.write(event_jsonl_line(event) + "\n")
            sys.stdout.flush()
            return
        if args.format != "text":
            return
        if event.get("event") != "response.output_text.delta":
            return
        text = str(event.get("text_delta") or "")
        if not text:
            return
        sys.stdout.write(text)
        sys.stdout.flush()
        saw_text = True

    def on_raw_line(line: str) -> None:
        if args.format != "raw":
            return
        sys.stdout.write(line + "\n")
        sys.stdout.flush()

    try:
        summary = run_gemini_event_stream(prompt, request, on_event=on_event, on_raw_line=on_raw_line)
    except RuntimeError as exc:
        sys.stderr.write(str(exc) + "\n")
        return 1
    if args.format == "text" and saw_text:
        sys.stdout.write("\n")
        sys.stdout.flush()
    if summary.ok:
        return 0
    sys.stderr.write((summary.error or "Gemini direct stream failed").rstrip() + "\n")
    return 1


def main() -> int:
    args = parse_args()
    try:
        prompt = read_prompt_text(args.prompt)
    except RuntimeError as exc:
        raise SystemExit(str(exc))
    return stream_request(prompt, args)


if __name__ == "__main__":
    raise SystemExit(main())
