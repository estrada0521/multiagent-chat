#!/usr/bin/env bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]:-$0}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SCRIPT_PATH="$LINK_TARGET"
  else
    SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET"
  fi
done

SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

usage() {
  cat <<'EOF'
Usage: multiagent-release <version> [options]

Create or update a GitHub Release from docs/updates/beta-<version>.md.

Options:
  --tag <tag>        release tag (default: beta-<version>)
  --notes <path>     notes file path (default: docs/updates/<tag>.md)
  --repo <owner/repo>
                     override GitHub repository for gh release commands
  --asset <path>     upload an asset to the release; repeat for multiple assets
  --create-tag       create and push the tag before publishing the release
  --draft            create release as draft (create path only)
  --prerelease       mark release as prerelease (create path only)
  --dry-run          print commands without executing
  -h, --help         show this help
EOF
}

VERSION=""
TAG=""
NOTES_PATH=""
REPO_SLUG=""
ASSETS=()
CREATE_TAG=0
DRAFT=0
PRERELEASE=0
DRY_RUN=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tag)
      TAG="${2:-}"
      shift 2
      ;;
    --notes)
      NOTES_PATH="${2:-}"
      shift 2
      ;;
    --repo)
      REPO_SLUG="${2:-}"
      shift 2
      ;;
    --asset)
      ASSETS+=("${2:-}")
      shift 2
      ;;
    --create-tag)
      CREATE_TAG=1
      shift
      ;;
    --draft)
      DRAFT=1
      shift
      ;;
    --prerelease)
      PRERELEASE=1
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -z "$VERSION" ]]; then
        VERSION="$1"
      else
        echo "Unexpected argument: $1" >&2
        usage >&2
        exit 1
      fi
      shift
      ;;
  esac
done

if [[ -z "$VERSION" ]]; then
  usage >&2
  exit 1
fi

if [[ -z "$TAG" ]]; then
  TAG="beta-${VERSION}"
fi

if [[ -z "$NOTES_PATH" ]]; then
  NOTES_PATH="docs/updates/${TAG}.md"
fi
if [[ "$NOTES_PATH" != /* ]]; then
  NOTES_PATH="${REPO_ROOT}/${NOTES_PATH}"
fi

if [[ ! -f "$NOTES_PATH" ]]; then
  echo "Release notes not found: $NOTES_PATH" >&2
  exit 1
fi

for asset in "${ASSETS[@]}"; do
  if [[ -z "$asset" ]]; then
    echo "Asset path cannot be empty." >&2
    exit 1
  fi
  if [[ ! -f "$asset" ]]; then
    echo "Release asset not found: $asset" >&2
    exit 1
  fi
done

if ! command -v git >/dev/null 2>&1; then
  echo "git is required." >&2
  exit 1
fi
if ! command -v gh >/dev/null 2>&1; then
  echo "gh CLI is required." >&2
  exit 1
fi

run_cmd() {
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf '[dry-run]'
    for arg in "$@"; do
      printf ' %q' "$arg"
    done
    printf '\n'
    return 0
  fi
  "$@"
}

if [[ "$CREATE_TAG" -eq 1 ]]; then
  if git rev-parse -q --verify "refs/tags/${TAG}" >/dev/null 2>&1; then
    echo "Tag already exists locally: ${TAG}"
  else
    run_cmd git -C "$REPO_ROOT" tag -a "$TAG" -m "multiagent-chat ${TAG}"
  fi
  run_cmd git -C "$REPO_ROOT" push origin "refs/tags/${TAG}"
else
  if ! git -C "$REPO_ROOT" ls-remote --exit-code --tags origin "refs/tags/${TAG}" >/dev/null 2>&1; then
    echo "Tag not found on origin: ${TAG}" >&2
    echo "Push the tag first, or rerun with --create-tag." >&2
    exit 1
  fi
fi

title="multiagent-chat ${TAG//-/ }"
if [[ -n "$REPO_SLUG" ]]; then
  release_exists_cmd=(gh release view "$TAG" --repo "$REPO_SLUG")
else
  release_exists_cmd=(gh release view "$TAG")
fi

if "${release_exists_cmd[@]}" >/dev/null 2>&1; then
  if [[ -n "$REPO_SLUG" ]]; then
    run_cmd gh release edit "$TAG" --title "$title" --notes-file "$NOTES_PATH" --repo "$REPO_SLUG"
  else
    run_cmd gh release edit "$TAG" --title "$title" --notes-file "$NOTES_PATH"
  fi
else
  create_cmd=(gh release create "$TAG" --verify-tag --title "$title" --notes-file "$NOTES_PATH")
  if [[ "$DRAFT" -eq 1 ]]; then
    create_cmd+=(--draft)
  fi
  if [[ "$PRERELEASE" -eq 1 ]]; then
    create_cmd+=(--prerelease)
  fi
  if [[ -n "$REPO_SLUG" ]]; then
    create_cmd+=(--repo "$REPO_SLUG")
  fi
  run_cmd "${create_cmd[@]}"
fi

if [[ "${#ASSETS[@]}" -gt 0 ]]; then
  upload_cmd=(gh release upload "$TAG" "${ASSETS[@]}" --clobber)
  if [[ -n "$REPO_SLUG" ]]; then
    upload_cmd+=(--repo "$REPO_SLUG")
  fi
  run_cmd "${upload_cmd[@]}"
fi

echo "Release operation completed for ${TAG}"
